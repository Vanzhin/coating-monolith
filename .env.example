# Docker Compose Variables
DOMAIN=1helper.ru
DB_EXTERNAL_PORT=5432

# Registry and Image
REGISTRY=ghcr.io
IMAGE_NAME=vanzhin/coating-monolith
TAG=latest

# Database
DB_NAME=coating
DB_USER=coating
DB_PASSWORD=changeme-strong-password
DB_HOST=manager_db
DB_PORT=5432

# Redis
REDIS_HOST=manager_redis

# Application
INSTALL_XDEBUG=false
APP_SECRET=changeme-generate-via-openssl-rand-hex-32
APP_NAME=Coating Monolith
DEFAULT_FROM_ADDR=noreply@1helper.ru
DEFAULT_FROM_NAME=1Helper
MAILER_DSN=smtp://localhost:1025

# JWT
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=changeme-jwt-passphrase

# Telegram Logging
LOG_TELEGRAM_BOT_KEY=changeme-telegram-bot-api-key
LOG_TELEGRAM_CHANNEL=changeme-telegram-channel-id
