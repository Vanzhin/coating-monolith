{#<div class="d-flex gap-2 mb-3">#}
    {% if duplicate is defined %}
        <a href="{{ path(duplicate, {'from': id}) }}" type="button" class="btn btn-outline-info" title="Дублировать">
            <i class="bi bi-files"></i>
        </a>
    {% endif %}
    <a href="{{ path(edit, {'id': id}) }}" type="button" class="btn btn-outline-primary" title="Редактировать">
        <i class="bi bi-pencil"></i>
    </a>
{#    <a class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#deleteModal"#}

{#    >#}
    <a href="{{ path(delete, {'id': id}) }}"
       type="button"
       data-bs-toggle="modal"
       data-bs-target="#deleteModal"
       class="btn btn-outline-danger"
       data-bs-title="{{ title }}"
       data-bs-id="{{ id }}"
    >
        <i class="bi bi-trash3"></i>
    </a>
{#</div>#}
