{% apply inline_css(source('@styles/email/email.css')) %}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ app_name }}{% endblock %}</title>
</head>
<body>
    <div class="container">
        <div class="header">
            <a class="brand" href="{{ app.request.server.get('CORS_ALLOW_ORIGIN') }}">{{ app_name }}</a>
        </div>

        <div class="body">
            {% block body %}{% endblock %}
        </div>

        <div class="footer">
            {% block footer %}
                © {{ 'now'|date('Y') }} {{ app_name }} · Автоматическое письмо, не отвечайте на него.
            {% endblock %}
        </div>
    </div>
</body>
</html>
{% endapply %}
