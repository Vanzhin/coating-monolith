<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{ app_name }} - профессиональная платформа для управления документами и покрытиями">
    <title>{% block title %}{{ app_name }} | {% endblock %}</title>

    {# FOUC-safe theme init — ставим data-bs-theme на <html> ДО того как браузер
       начнёт применять Bootstrap CSS, чтобы не «моргнуть» светлой темой при
       загрузке. Bootstrap 5.3+ читает атрибут и применяет соответствующие
       CSS-переменные (--bs-body-bg / --bs-body-color / border-color / etc). #}
    <script>
        (function () {
            try {
                var stored = localStorage.getItem('theme');
                var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                document.documentElement.setAttribute('data-bs-theme', theme);
            } catch (e) { /* localStorage может быть заблокирован — оставляем дефолт */ }
        })();
    </script>

    {# Favicon и манифест #}
    <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('icons/apple-touch-icon.png') }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('icons/favicon-32x32.png') }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('icons/favicon-16x16.png') }}">
    <link rel="icon" href="{{ asset('icons/favicon.ico') }}" sizes="16x16 32x32"/>
    <link rel="manifest" href="{{ asset('icons/site.webmanifest') }}">

    {# Bootstrap Icons бандлятся локально через assets/styles/bootstrap-icons.css
       (импортируется из app.css). CDN-линк убран — он грузил иконки повторно
       поверх локального бандла. #}

    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}

    <style>
        :root {
            --primary-color: #007bff;
            --secondary-color: #6c757d;
        }

        body {
            /* fallback для <iOS 15.4 / <Chrome 108; dvh учитывает iOS Safari
               address-bar (без него контент скачет при show/hide URL-бара). */
            min-height: 100vh;
            min-height: 100dvh;
            display: flex;
            flex-direction: column;
        }

        main {
            flex: 1;
        }

        .blog-header {
            border-bottom: 1px solid #e5e5e5;
            position: relative;
            z-index: 1030;
            background: white;
        }

        .blog-header-logo {
            font-family: inherit;
            font-size: 1.25rem;
            text-decoration: none;
        }

        .blog-header-logo:hover {
            text-decoration: none;
        }

        .flash-messages {
            position: fixed;
            top: 90px;
            right: 20px;
            z-index: 1050;
            max-width: 400px;
            background-color: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(8px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.12);
            border-radius: 8px;
            padding: 0;
        }

        .flash-messages .alert {
            margin: 0;
            box-shadow: none;
            border: 1px solid rgba(0, 0, 0, 0.06);
        }


        /* Кнопка hamburger'a в шапке — единая для мобильной и десктопа.
           Раньше была floating (position:fixed) и показывалась только на мобильной;
           теперь встроена в левую колонку хедера и работает как единый источник
           навигации на всех устройствах. */
        .menu-toggle {
            width: 40px;
            height: 40px;
            padding: 0;
            border-radius: 6px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .menu-toggle .bi-list {
            font-size: 1.2rem;
        }

        @media (max-width: 576px) {
            .blog-header-logo {
                font-size: 1.5rem;
            }

            .menu-toggle {
                width: 36px;
                height: 36px;
            }

            .flash-messages {
                top: 90px;
                left: 20px;
                right: 20px;
                max-width: none;
            }
        }

        .back-to-top {
            position: fixed;
            /* safe-area-inset-* — отступ от iOS home-bar / notch на iPhone X+. */
            bottom: calc(20px + env(safe-area-inset-bottom, 0px));
            right: calc(20px + env(safe-area-inset-right, 0px));
            z-index: 1000;
            display: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Touch-target ≥44px (Apple HIG, WCAG 2.5.5 AA) для duration-кнопок
           на mobile. На desktop остаётся btn-sm — там mouse-pointer. */
        @media (max-width: 767.98px) {
            .duration-display-btn {
                min-height: 44px;
            }
        }

        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
            background-color: #dee2e6;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .user-avatar i {
            font-size: 16px;
            color: #6c757d;
        }

        /* Offcanvas меню */
        .offcanvas-header {
            border-bottom: 1px solid #dee2e6;
            padding: 1rem 1.5rem;
        }

        .offcanvas-title {
            font-weight: 600;
        }

        .offcanvas-body {
            padding: 0;
        }

        /* Стили пунктов меню — ТОЛЬКО внутри #mainMenu, чтобы не перекрывать
           .list-group-item на карточках покрытий/производителей (там дефолтный
           Bootstrap hover нужен и корректно работает в тёмной теме через
           --bs-list-group-*-* переменные). */
        #mainMenu .list-group-item {
            border: none;
            border-radius: 0;
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--bs-border-color);
            background: transparent;
        }

        #mainMenu .list-group-item:hover {
            background-color: var(--bs-tertiary-bg);
        }

        #mainMenu .list-group-item i {
            width: 20px;
        }

        /* Секция пользователя в мобильном меню — тоже theme-aware. */
        .user-section {
            background-color: var(--bs-tertiary-bg);
            border-bottom: 1px solid var(--bs-border-color);
        }

        .user-info {
            padding: 1rem 1.5rem;
        }

        .user-email {
            font-weight: 500;
            color: #495057;
        }

        /* === GitHub-inspired refresh ===
           Системный шрифт-стек (нативный на каждой ОС), плотная типографика,
           мягкие границы, больше воздуха в карточках/list-item'ах. Работает
           поверх Bootstrap: не заменяет базовые классы, только уточняет.

           Тёмная тема — через встроенный Bootstrap 5.3 механизм
           `data-bs-theme="dark"` на <html> (см. FOUC-safe init script в head). */
        body {
            /* Office-style стек: Calibri на Windows (Office-default), Segoe UI
               fallback там же; на macOS — системный SF Pro / Helvetica Neue;
               на Linux — Ubuntu / DejaVu. Всё нативно, без внешних загрузок. */
            font-family: Calibri, "Segoe UI", -apple-system, BlinkMacSystemFont,
                         "Helvetica Neue", "Noto Sans", Arial, sans-serif,
                         "Apple Color Emoji", "Segoe UI Emoji";
            font-size: 15px;
            -webkit-font-smoothing: antialiased;
            text-rendering: optimizeLegibility;
        }

        h1, h2, h3, h4, h5, h6, .h1, .h2, .h3, .h4, .h5, .h6 {
            font-weight: 600;
            line-height: 1.25;
            letter-spacing: -0.005em;
        }

        /* Логотип — не Playfair, а тот же системный шрифт что и body: плотный
           weight и tight letter-spacing вместо декоративной засечки. */
        .blog-header-logo {
            font-family: inherit;
            font-weight: 700;
            font-size: 1.25rem;
            letter-spacing: -0.02em;
        }

        /* Шапка — использует CSS-переменные Bootstrap, чтобы автоматически
           переключаться со светлой на тёмную. */
        .blog-header {
            background: var(--bs-body-bg);
            border-bottom: 1px solid var(--bs-border-color);
        }

        /* Больше воздуха в списках-карточках, мягкая граница. */
        .list-group {
            border-radius: 8px;
            --bs-list-group-border-color: var(--bs-border-color);
        }
        .list-group-item {
            padding: 1rem 1.25rem;
            transition: background-color 0.15s ease;
        }
        /* Hover-выделение карточек: --bs-secondary-bg даёт видимый контраст
           в обеих темах (#e9ecef в светлой, #343a40 в тёмной) и не ломает
           читаемость текста (цвет тела не меняем). */
        .list-group-item:hover {
            background-color: var(--bs-secondary-bg);
        }

        .card {
            border-radius: 8px;
            border-color: var(--bs-border-color);
        }

        /* Flash-сообщения — прозрачнее, чтобы не выбивались из тёмной темы. */
        .flash-messages {
            background-color: transparent;
            backdrop-filter: none;
            box-shadow: none;
        }
        .flash-messages .alert {
            background-color: var(--bs-body-bg);
            border-color: var(--bs-border-color);
        }

        /* Модалка / offcanvas в тёмной теме получают правильные фон/бордер
           через встроенный Bootstrap 5.3 — доп. правки не нужны. */

        /* Кнопка переключения темы: одинаковый размер с .menu-toggle. */
        .theme-toggle {
            width: 40px;
            height: 40px;
            padding: 0;
            border-radius: 6px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .theme-toggle .bi { font-size: 1.1rem; }
        @media (max-width: 576px) {
            .theme-toggle { width: 36px; height: 36px; }
        }
    </style>
</head>
<body>
{% block header %}
    <header class="blog-header py-3">
        <div class="container-fluid">
            <div class="row flex-nowrap justify-content-between align-items-center">
                {# Левая колонка — hamburger, открывающий единое меню (offcanvas).
                   На всех разрешениях: замена бывшего mobile-only floating-бургера
                   и cabinet sidebar'а. #}
                <div class="col-4 d-flex align-items-center">
                    <button class="btn btn-outline-secondary menu-toggle shadow-sm" type="button"
                            data-bs-toggle="offcanvas" data-bs-target="#mainMenu"
                            aria-label="Открыть меню">
                        <i class="bi bi-list"></i>
                    </button>
                </div>

                {# Центральная колонка - логотип #}
                <div class="col-4 text-center">
                    <a class="blog-header-logo text-body text-decoration-none" href="{{ path('app_homepage') }}">
                        {{ app_name }}
                    </a>
                </div>

                {# Правая колонка — переключатель темы. Пункты пользователя
                   (Кабинет / Выйти / Войти) живут в `#mainMenu` offcanvas'e. #}
                <div class="col-4 d-flex justify-content-end align-items-center">
                    <button type="button"
                            class="btn btn-outline-secondary theme-toggle shadow-sm"
                            id="themeToggle"
                            aria-label="Переключить тему">
                        <i class="bi bi-sun-fill" data-theme-icon="light"></i>
                        <i class="bi bi-moon-stars-fill d-none" data-theme-icon="dark"></i>
                    </button>
                </div>
            </div>
        </div>
    </header>
{% endblock %}

{# Flash сообщения #}
<div class="flash-messages">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type }} alert-dismissible fade show shadow" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% if is_granted('IS_IMPERSONATOR') %}
        <div class="alert alert-warning alert-dismissible fade show shadow" role="alert">
            Вы находитесь в режиме исполнения роли
            <a href="{{ impersonation_exit_path(path('app_homepage')) }}" class="alert-link">Выйти из режима</a>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endif %}
</div>

<main class="container-fluid">
    <div class="container py-4">
        {% block body %}{% endblock %}
    </div>
</main>

{# Кнопка "Наверх" #}
<button class="btn btn-primary back-to-top shadow" onclick="scrollToTop()" title="Наверх">
    <i class="bi bi-arrow-up"></i>
</button>

{% block footer %}
    <footer class="bg-dark text-white py-4 mt-auto">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 mb-3 mb-md-0">
                    <p class="mb-0">&copy; {{ "now"|date("Y") }} 1helper</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <ul class="nav justify-content-md-end">
                        <li class="nav-item">
                            <a href="#" class="nav-link px-2 text-body-secondary text-white-50" onclick="scrollToTop(); return false;">Наверх</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>
{% endblock %}

{# Мобильное offcanvas меню - ТОЛЬКО ОДНО #}
<div class="offcanvas offcanvas-start" tabindex="-1" id="mainMenu" aria-labelledby="mainMenuLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="mainMenuLabel">Меню</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Закрыть"></button>
    </div>
    <div class="offcanvas-body">
        {# Секция информации о пользователе #}
        {% if app.user %}
            <div class="user-section">
                <div class="user-info">
                    <div class="d-flex align-items-center">
                        <div class="user-avatar me-3">
                            <i class="bi bi-person"></i>
                        </div>
                        <div>
                            <div class="user-email">{{ app.user.email }}</div>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}

        <div class="list-group list-group-flush">
            <a href="{{ path('app_homepage') }}" class="list-group-item list-group-item-action">
                <i class="bi bi-house me-2"></i>Главная
            </a>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_cabinet_coating_coating_list') }}" class="list-group-item list-group-item-action">
                    <i class="bi bi-grid me-2"></i>Покрытия
                </a>
                <a href="{{ path('app_cabinet_coating_manufacturer_list') }}" class="list-group-item list-group-item-action">
                    <i class="bi bi-building me-2"></i>Производители
                </a>
            {% endif %}
            <hr class="my-2">

            {# Ссылки связанные с аккаунтом #}
            {% if app.user %}
                <a href="{{ path('app_cabinet') }}" class="list-group-item list-group-item-action">
                    <i class="bi bi-person-circle me-2"></i>Личный кабинет
                </a>
                <a href="{{ path('app_logout') }}" class="list-group-item list-group-item-action text-danger">
                    <i class="bi bi-box-arrow-right me-2"></i>Выйти из аккаунта
                </a>
            {% else %}
                <a href="{{ path('app_login') }}" class="list-group-item list-group-item-action">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Войти в аккаунт
                </a>
                <a href="{{ path('app_sign_up') }}" class="list-group-item list-group-item-action">
                    <i class="bi bi-person-plus me-2"></i>Зарегистрироваться
                </a>
            {% endif %}
        </div>
    </div>
</div>

<script>
    // Скролл к верху страницы
    function scrollToTop() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Показ/скрытие кнопки "Наверх"
    window.addEventListener('scroll', function() {
        const backToTopBtn = document.querySelector('.back-to-top');
        if (window.scrollY > 300) {
            backToTopBtn.style.display = 'flex';
        } else {
            backToTopBtn.style.display = 'none';
        }
    });

    document.addEventListener('DOMContentLoaded', function() {
        // Автоматическое скрытие flash-toast'ов: success'ы — 5 сек (короткое
        // подтверждение), warning/danger/info — 10 сек (нужно успеть прочитать,
        // но пропадают сами). Inline-алерты (не в .flash-messages) остаются
        // до явного dismiss — это контентные сообщения (empty-state, ошибки
        // формы), а не toast'ы.
        const closeAfter = (selector, delay) => {
            document.querySelectorAll(selector).forEach(alert => {
                setTimeout(() => {
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                }, delay);
            });
        };
        closeAfter('.flash-messages .alert-success', 5000);
        closeAfter('.flash-messages .alert:not(.alert-success)', 10000);

        // Инициализация tooltips
        const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });

        // Переключение темы — актуальная тема на <html data-bs-theme=...>
        // выставляется FOUC-safe скриптом в <head>. Здесь только синхронизируем
        // иконку и обрабатываем клик.
        const themeToggleBtn = document.getElementById('themeToggle');
        if (themeToggleBtn) {
            const syncIcon = () => {
                const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                themeToggleBtn.querySelector('[data-theme-icon="light"]').classList.toggle('d-none', isDark);
                themeToggleBtn.querySelector('[data-theme-icon="dark"]').classList.toggle('d-none', !isDark);
            };
            syncIcon();
            themeToggleBtn.addEventListener('click', () => {
                const next = document.documentElement.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-bs-theme', next);
                try { localStorage.setItem('theme', next); } catch (e) {}
                syncIcon();
            });
        }

        // Закрытие меню при клике на ссылку — иначе пользователь выбрал раздел
        // и остался с открытым offcanvas'ом, приходится закрывать вручную.
        document.querySelectorAll('#mainMenu .list-group-item').forEach(item => {
            item.addEventListener('click', function() {
                const bsOffcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('mainMenu'));
                if (bsOffcanvas) {
                    bsOffcanvas.hide();
                }
            });
        });
    });
</script>
</body>
</html>