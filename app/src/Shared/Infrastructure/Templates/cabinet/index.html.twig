{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} Кабинет{% endblock %}

{% block body %}
    {# Sidebar удалён — навигация вынесена в единый offcanvas `#mainMenu` в base.
       Content-area теперь занимает всю ширину; layout — просто main без
       sidebar-колонки. #}
    <main class="container-fluid py-3">
        {% block content %}
            <div class="container-fluid">
                {% if is_granted('IS_IMPERSONATOR') %}
                    <div class="alert alert-warning d-block">
                        Вы находитесь в режиме исполнения роли
                        <a href="{{ impersonation_exit_path(path('app_homepage')) }}" class="alert-link">
                            Выйти из режима
                        </a>
                    </div>
                {% endif %}

                {% if app.session.flashBag.peekAll()|length > 0 %}
                    <div class="alert alert-warning alert-dismissible fade show" role="alert">
                        {% for key, messages in app.flashes() %}
                            {% for message in messages %}
                                <span>{{ message }}</span>
                            {% endfor %}
                        {% endfor %}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endif %}

                <div class="content-area">
                    <h3>Здесь будут данные для пользователя - Тест1</h3>
                </div>
            </div>
        {% endblock %}
    </main>
{% endblock %}

