{% extends '/cabinet/index.html.twig' %}

{% block title %}{{ parent() }} | Обновление производителя{% endblock %}

{% block content %}
    <div class="col-lg-10 mx-auto p-4 py-md-5">
        <form method="post" action="{{ path('app_cabinet_coating_manufacturer_update', {id: result.manufacturer.id}) }}" class="w-100">
            {% if error %}
                <div class="alert alert-danger">{{ error }}</div>
            {% endif %}

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0">Обновление производителя</h1>
                <a href="{{ path('app_cabinet_coating_manufacturer_list') }}" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left"></i> К списку
                </a>
            </div>

            <div class="card mb-3">
                <div class="card-header fw-semibold">Описание</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="inputTitle" class="form-label">Название</label>
                            <input type="text" value="{{ result.manufacturer.title }}" name="title" id="inputTitle"
                                   class="form-control" required autofocus minlength="3" maxlength="50"
                                   placeholder="Укажите название...">
                        </div>
                        <div class="col-12">
                            <label for="inputDescription" class="form-label">Описание</label>
                            <textarea name="description" id="inputDescription" class="form-control"
                                      rows="4" maxlength="750" required
                                      placeholder="Укажите описание...">{{ result.manufacturer.description }}</textarea>
                            <div class="form-text">до 750 символов</div>
                        </div>
                    </div>
                </div>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="d-flex justify-content-end gap-2">
                <a href="{{ path('app_cabinet_coating_manufacturer_list') }}" class="btn btn-outline-secondary">Отмена</a>
                <button class="btn btn-primary" type="submit">Сохранить</button>
            </div>
        </form>
    </div>
{% endblock %}
