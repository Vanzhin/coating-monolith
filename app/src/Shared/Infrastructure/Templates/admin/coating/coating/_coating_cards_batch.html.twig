{# Батч карточек покрытий + их preview-модалок.
   Используется:
   - основным шаблоном index.html.twig для первой страницы;
   - ListAction в режиме ?partial=1 для догрузки следующих страниц через
     infinite-list Stimulus-контроллер — тогда возвращается ТОЛЬКО этот
     partial без layout'a.

   Обязательные переменные:
     coatings          — list<CoatingDTO>
     canEdit           — bool
     selectedTagIdList — list<string>  (id уже активных tag-фильтров)
#}
{% for coating in coatings %}
    {# Карточка покрытия — bg-body поверх тертиарного контейнера (см. list_page.html.twig),
       чтобы был контраст между «зоной» и «элементом внутри неё». Раньше был
       list-group-item с бортиками — новый паттерн через p-3 rounded-3.
       coating-card — фиксирует одинаковую min-height (см. index.html.twig),
       чтобы карточки с коротким описанием / без тегов не «подскакивали». #}
    <div class="coating-card d-flex align-items-start gap-2 gap-md-3 p-3 rounded-3 bg-body">
        <div class="form-check flex-shrink-0 m-0 mt-1">
            <input type="checkbox" class="form-check-input m-0"
                   data-compare-id="{{ coating.id }}"
                   data-action="change->compare-tray#toggle"
                   aria-label="Добавить к сравнению">
        </div>
        <div class="flex-grow-1 overflow-hidden">
            {# Модалку-триггер вешаем ТОЛЬКО на title+description, не на всю
               обёртку. Иначе клик по tag-ссылке пузырьком триггерит модалку
               (stopPropagation на inline onclick был fragile из-за event
               delegation в Bootstrap 5). #}
            <div style="cursor: pointer;"
                 data-bs-toggle="modal"
                 data-bs-target="#coatingPreview-{{ coating.id }}">
                <h6 class="mb-1 fw-semibold" style="word-break: break-word;">{{ coating.title }}</h6>
                <p class="mb-1 small text-muted coating-card-desc">
                    {{ coating.description }}
                </p>
            </div>
            {% if coating.matchedSubstances is defined and coating.matchedSubstances|length > 0 %}
                {% set matches = coating.matchedSubstances %}
                {% set visible = matches|slice(0, 3) %}
                {% set hidden = matches|length - visible|length %}
                <div class="d-flex flex-wrap gap-1 align-items-center mb-1 coating-match-substances">
                    <span class="small text-success-emphasis fw-medium me-1">✓ Стойкое к:</span>
                    {% for m in visible %}
                        <a href="#"
                           data-bs-toggle="modal"
                           data-bs-target="#coatingPreview-{{ coating.id }}"
                           data-controller="substance-badge"
                           data-substance-badge-id-value="{{ m.substanceId }}"
                           class="badge text-bg-success bg-opacity-25 text-body-emphasis fw-normal text-decoration-none">
                            {{ m.canonicalName }}
                        </a>
                    {% endfor %}
                    {% if hidden > 0 %}
                        <span class="badge text-bg-light fw-normal">+{{ hidden }} ещё</span>
                    {% endif %}
                </div>
            {% endif %}
            {% if coating.tags|length > 0 %}
                {# Теги в одну строку с горизонтальным скроллом. При большом
                   количестве тегов не растягивают карточку по высоте — CSS
                   для .coating-tags-scroll лежит в index.html.twig.
                   data-controller="scroll-fade" — общий Stimulus-контроллер,
                   выставляет классы .scroll-fade-at-start/-at-end, чтобы
                   CSS убирал fade-градиент когда скролл упёрся в край. #}
                <div class="d-flex flex-nowrap gap-1 coating-tags-scroll"
                     data-controller="scroll-fade">
                    {% for tag in coating.tags %}
                        {% set isActive = tag.id in selectedTagIdList %}
                        {% set newTagIds = isActive
                            ? selectedTagIdList|filter(id => id != tag.id)
                            : selectedTagIdList|merge([tag.id]) %}
                        {% set q = app.request.query.all|merge({tagIds: newTagIds, page: null})|filter(v => v is not null) %}
                        <a href="{{ path('app_cabinet_coating_coating_list', q) }}"
                           class="badge text-bg-{{ tag.type|tag_bootstrap_color }}{% if not isActive %} bg-opacity-25 text-body-emphasis{% endif %} fw-normal text-decoration-none flex-shrink-0"
                           title="{{ isActive ? 'Убрать «' ~ tag.title ~ '» из фильтра' : 'Отфильтровать по «' ~ tag.title ~ '»' }}">
                            {{ tag.title }}
                            {%- if isActive %} ×{% endif -%}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
        {% if canEdit %}
            <div class="d-flex gap-1 gap-md-2 flex-shrink-0 flex-column flex-md-row">
                {% include '/components/edit_delete.html.twig'
                    with {
                    'edit': 'app_cabinet_coating_coating_update',
                    'delete':'app_cabinet_coating_coating_delete',
                    'duplicate': 'app_cabinet_coating_coating_create',
                    'id': coating.id,
                    'title': coating.title,
                    'name': "покрытие"
                } %}
            </div>
        {% endif %}
    </div>

    <div class="modal fade" id="coatingPreview-{{ coating.id }}" tabindex="-1"
         aria-labelledby="coatingPreviewLabel-{{ coating.id }}" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title mb-0" id="coatingPreviewLabel-{{ coating.id }}">
                            {{ coating.title }}
                        </h5>
                        <small class="text-muted">{{ coating.manufacturer.title }}</small>
                    </div>
                    <button type="button" class="btn-close"
                            data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body">
                    {% if coating.tags|length > 0 or coating.description %}
                        <div class="p-3 mb-3 rounded-3 bg-body-tertiary">
                            {% if coating.tags|length > 0 %}
                                <div class="{% if coating.description %}mb-3 {% endif %}d-flex flex-wrap gap-1">
                                    {% for tag in coating.tags %}
                                        <span class="badge text-bg-{{ tag.type|tag_bootstrap_color }} fw-normal">{{ tag.title }}</span>
                                    {% endfor %}
                                </div>
                            {% endif %}
                            {% if coating.description %}
                                <p class="text-body-secondary mb-0">{{ coating.description }}</p>
                            {% endif %}
                        </div>
                    {% endif %}

                    {# Форматирование ThermalExposureLimits: continuous_min…continuous_max
                       (обе границы включительно, null-граница = «не задокументировано»),
                       + опциональный «пик X °C, N мин». Показываем только если у нас
                       есть хоть одно значение — null-DTO пропускаем. #}
                    {% macro thermalRange(exposure) %}
                        {% if exposure %}
                            {% set cMin = exposure.continuous_min %}
                            {% set cMax = exposure.continuous_max %}
                            {% if cMin is not null and cMax is not null %}
                                {{ cMin > 0 ? '+' ~ cMin : cMin }} … {{ cMax > 0 ? '+' ~ cMax : cMax }}
                            {% elseif cMax is not null %}
                                ≤ {{ cMax > 0 ? '+' ~ cMax : cMax }}
                            {% elseif cMin is not null %}
                                ≥ {{ cMin > 0 ? '+' ~ cMin : cMin }}
                            {% endif %}
                            {% if exposure.peak_max is not null %}
                                <span class="text-muted small">
                                    (пик до {{ exposure.peak_max > 0 ? '+' ~ exposure.peak_max : exposure.peak_max }}
                                    {%- if exposure.peak_duration_minutes %}, {{ exposure.peak_duration_minutes }} мин{% endif -%}
                                    )
                                </span>
                            {% endif %}
                        {% endif %}
                    {% endmacro %}

                    <div class="p-3 mb-3 rounded-3 bg-body-tertiary">
                        <h6 class="fw-semibold mb-3">Основные характеристики</h6>
                        <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0 table-rows">
                            <tbody>
                                {% set baseEnum = coating.baseEnum %}
                                {% if baseEnum %}
                                    <tr>
                                        <th scope="row" class="text-muted fw-normal" style="width: 60%;">Тип ЛКМ</th>
                                        <td>
                                            {{ baseEnum.title }}
                                            <span class="text-muted">
                                                ({{ baseEnum.iso }}{% if baseEnum.gost|length > 0 %} / {{ baseEnum.gost|join(', ') }}{% endif %})
                                            </span>
                                        </td>
                                    </tr>
                                {% endif %}
                                <tr>
                                    <th scope="row" class="text-muted fw-normal" style="width: 60%;">Сухой остаток, об. %</th>
                                    <td>{{ coating.volumeSolid }}</td>
                                </tr>
                                <tr>
                                    <th scope="row" class="text-muted fw-normal">Плотность, кг/л</th>
                                    <td>{{ coating.massDensity }}</td>
                                </tr>
                                <tr>
                                    <th scope="row" class="text-muted fw-normal">Толщина сухой плёнки, мкм</th>
                                    <td>
                                        {{ coating.dftRange.min }}–{{ coating.dftRange.max }}
                                        <span class="text-muted">(целевая {{ coating.dftRange.tds_dft }})</span>
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row" class="text-muted fw-normal">Диапазон нанесения, °C</th>
                                    <td>{{ coating.applicationMinTemp }} … {{ coating.dryingMaxTemp }}</td>
                                </tr>
                                {% if coating.dryHeatExposure %}
                                    <tr>
                                        <th scope="row" class="text-muted fw-normal">Эксплуатация в сухом тепле, °C</th>
                                        <td>{{ _self.thermalRange(coating.dryHeatExposure) }}</td>
                                    </tr>
                                {% endif %}
                                {% if coating.immersionExposure %}
                                    <tr>
                                        <th scope="row" class="text-muted fw-normal">Эксплуатация в погружении, °C</th>
                                        <td>{{ _self.thermalRange(coating.immersionExposure) }}</td>
                                    </tr>
                                {% endif %}
                                <tr>
                                    <th scope="row" class="text-muted fw-normal">Упаковка, л</th>
                                    <td>{{ coating.pack }}</td>
                                </tr>
                                {% if coating.thinner %}
                                    <tr>
                                        <th scope="row" class="text-muted fw-normal">Разбавитель</th>
                                        <td>{{ coating.thinner }}</td>
                                    </tr>
                                {% endif %}
                            </tbody>
                        </table>
                        </div>
                    </div>

                    {% set matrix = coating_time_matrix(coating) %}
                    <div class="p-3 mb-3 rounded-3 bg-body-tertiary">
                        <h6 class="fw-semibold mb-3">Время высыхания</h6>
                        <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0 table-rows">
                            <thead>
                                <tr>
                                    <th class="text-muted fw-normal">Температура поверхности</th>
                                    {% for t in matrix.columns %}
                                        <th class="text-muted fw-normal text-center text-nowrap">{{ t > 0 ? '+' ~ t : t }} °C</th>
                                    {% endfor %}
                                </tr>
                            </thead>
                            <tbody>
                                {% for row in matrix.rows %}
                                    <tr>
                                        <th scope="row" class="fw-normal">{{ row.label }}</th>
                                        {% for t in matrix.columns %}
                                            {% set cell = row.values[t] %}
                                            <td class="text-center text-nowrap {% if cell.is_calculated %}text-muted fst-italic{% endif %}">
                                                {% if cell.minutes is null %}
                                                    <span class="text-muted">—</span>
                                                {% elseif cell.minutes == 0 %}
                                                    <i class="bi bi-infinity" title="без ограничения"></i>
                                                {% else %}
                                                    {{ cell.minutes|duration_minutes_short }}
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        </div>
                    </div>
                    <p class="text-muted small mb-0">
                        Курсивом — рассчитанные интерполяцией значения.
                        «—» — данные отсутствуют или вне определённого диапазона.
                        {% if coating.maxRecoatingInterval is null %}
                            Верхняя граница интервала перекрытия не задана.
                        {% endif %}
                    </p>
                </div>
                <div class="modal-footer">
                    {% if canEdit %}
                        <a href="{{ path('app_cabinet_coating_coating_update', {id: coating.id}) }}"
                           class="btn btn-outline-primary">
                            <i class="bi bi-pencil"></i> Редактировать
                        </a>
                    {% endif %}
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
                </div>
            </div>
        </div>
    </div>
{% endfor %}
