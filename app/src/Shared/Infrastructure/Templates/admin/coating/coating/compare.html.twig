{% extends '/cabinet/index.html.twig' %}

{% block title %}{{ parent() }} | Сравнение покрытий{% endblock %}

{% block content %}
    {% set fieldLabels = {
        'title':                  'Название',
        'manufacturer.title':     'Производитель',
        'base':                   'Тип ЛКМ (ISO)',
        'volumeSolid':            'Сухой остаток, %',
        'massDensity':            'Плотность, кг/л',
        'pack':                   'Упаковка, л',
        'thinner':                'Разбавитель',
        'applicationMinTemp':     'Мин Т нанесения, °C',
        'dryingMaxTemp':          'Макс Т сушки, °C',
        'dftRange.min':           'Мин ТСП, мкм',
        'dftRange.max':           'Макс ТСП, мкм',
        'dftRange.tds_dft':       'Целевая ТСП, мкм',
    } %}

    <div class="container-fluid p-4" data-controller="compare-filter">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">Сравнение покрытий ({{ subjects|length }})</h1>
            <a href="{{ path('app_cabinet_coating_coating_list') }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> К списку
            </a>
        </div>

        <div class="row g-3">
            {# Сайдбар: чекбоксы видимых полей. Логика toggle — Stimulus в Task 7.
               На <lg сайдбар уходит ПОД таблицу (order-2), чтобы пользователь
               сразу видел сравнение и не скроллил через 15 чекбоксов. #}
            <aside class="col-lg-3 order-2 order-lg-1">
                <div class="card">
                    <div class="card-header fw-semibold small">Видимые поля</div>
                    <ul class="list-group list-group-flush">
                        {% for field in fields %}
                            <li class="list-group-item py-1">
                                <label class="form-check d-flex align-items-center gap-2 mb-0">
                                    <input type="checkbox" class="form-check-input m-0"
                                           data-compare-filter-target="checkbox"
                                           data-field="{{ field }}" checked>
                                    <span class="small">{{ fieldLabels[field] ?? field }}</span>
                                </label>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </aside>

            <main class="col-lg-9 order-1 order-lg-2">
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 20%;">Поле</th>
                                {% for subject in subjects %}
                                    <th>
                                        <div class="fw-semibold">{{ subject.title }}</div>
                                        <div class="text-muted small">{{ subject.manufacturer.title }}</div>
                                    </th>
                                {% endfor %}
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in comparison.rows %}
                                <tr data-compare-filter-target="row" data-field="{{ row.field }}"
                                    {% if row.isDifferent %}class="table-warning"{% endif %}>
                                    <th scope="row">{{ fieldLabels[row.field] ?? row.field }}</th>
                                    {% for value in row.values %}
                                        <td>{{ _self.format_value(row.field, value) }}</td>
                                    {% endfor %}
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {# ==== Время высыхания — per-subject matrix (тот же CoatingTimeMatrixBuilder,
                       что в preview-модалке). Колонки у каждого покрытия свои
                       (зависят от app_min..drying_max), поэтому таблицы стекаются
                       вертикально с card-заголовком. ==== #}
                <h2 class="h4 mt-5 mb-3">Время высыхания</h2>
                {% for subject in subjects %}
                    {% set matrix = coating_time_matrix(subject) %}
                    <div class="card mb-3">
                        <div class="card-header py-2">
                            <div class="fw-semibold">{{ subject.title }}</div>
                            <div class="text-muted small">{{ subject.manufacturer.title }}</div>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="text-muted fw-normal">Температура поверхности</th>
                                        {% for t in matrix.columns %}
                                            <th class="text-center text-nowrap">{{ t > 0 ? '+' ~ t : t }} °C</th>
                                        {% endfor %}
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for row in matrix.rows %}
                                        <tr>
                                            <th scope="row" class="fw-normal">{{ row.label }}</th>
                                            {% for t in matrix.columns %}
                                                {% set cell = row.values[t] %}
                                                <td class="text-center text-nowrap {% if cell.is_calculated %}text-muted fst-italic{% endif %}">
                                                    {% if cell.minutes is null %}
                                                        <span class="text-muted">—</span>
                                                    {% elseif cell.minutes == 0 %}
                                                        <i class="bi bi-infinity" title="без ограничения"></i>
                                                    {% else %}
                                                        {{ cell.minutes|duration_minutes_short }}
                                                    {% endif %}
                                                </td>
                                            {% endfor %}
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                            </div>
                        </div>
                    </div>
                {% endfor %}
                <p class="text-muted small">
                    Курсивом — рассчитанные интерполяцией значения.
                    «—» — данные отсутствуют или вне определённого диапазона.
                </p>
            </main>
        </div>
    </div>
{% endblock %}

{# Per-field форматтер для скалярных полей. #}
{% macro format_value(field, value) %}
    {% if value is null %}
        <span class="text-muted">—</span>
    {% else %}
        {{ value }}
    {% endif %}
{% endmacro %}
