{% extends '/cabinet/index.html.twig' %}

{% block title %}{{ parent() }} | Сравнение покрытий{% endblock %}

{# Заголовок subject'а с крестиком «убрать из сравнения» перед названием.
   Stimulus-контроллер compare-remove читает id, удаляет из URL и localStorage,
   редиректит на compare?ids=… или /list если осталось < 2 покрытия. #}
{% macro subject_head(subject) %}
    <div class="d-flex align-items-start gap-1">
        <button type="button"
                class="btn btn-sm btn-outline-danger border-0 p-0 lh-1 mt-1"
                data-controller="compare-remove"
                data-compare-remove-id-value="{{ subject.id }}"
                data-compare-remove-list-url-value="{{ path('app_cabinet_coating_coating_list') }}"
                data-action="click->compare-remove#remove"
                title="Убрать «{{ subject.title }}» из сравнения"
                aria-label="Убрать из сравнения">
            <i class="bi bi-x-lg"></i>
        </button>
        <div>
            <div class="fw-semibold">{{ subject.title }}</div>
            <div class="text-muted small">{{ subject.manufacturer.title }}</div>
        </div>
    </div>
{% endmacro %}

{% block content %}
    {% set fieldLabels = {
        'title':                  'Название',
        'manufacturer.title':     'Производитель',
        'base':                   'Тип ЛКМ (ISO)',
        'volumeSolid':            'Сухой остаток, %',
        'massDensity':            'Плотность, кг/л',
        'pack':                   'Упаковка, л',
        'thinner':                'Разбавитель',
        'applicationMinTemp':     'Мин Т нанесения, °C',
        'dryingMaxTemp':          'Макс Т сушки, °C',
        'dftRange.min':           'Мин ТСП, мкм',
        'dftRange.max':           'Макс ТСП, мкм',
        'dftRange.tds_dft':       'Целевая ТСП, мкм',
    } %}

    <div class="container-fluid p-4" data-controller="compare-filter">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">Сравнение покрытий ({{ subjects|length }})</h1>
            <a href="{{ path('app_cabinet_coating_coating_list') }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> К списку
            </a>
        </div>

        <div class="row g-3">
            {# Сайдбар: чекбоксы видимых полей. Логика toggle — Stimulus в Task 7.
               На <lg сайдбар уходит ПОД таблицу (order-2), чтобы пользователь
               сразу видел сравнение и не скроллил через 15 чекбоксов. #}
            <aside class="col-lg-3 order-2 order-lg-1">
                <div class="card">
                    <div class="card-header fw-semibold small">Видимые поля</div>
                    <ul class="list-group list-group-flush">
                        {% for field in fields %}
                            <li class="list-group-item py-1">
                                <label class="form-check d-flex align-items-center gap-2 mb-0">
                                    <input type="checkbox" class="form-check-input m-0"
                                           data-compare-filter-target="checkbox"
                                           data-field="{{ field }}" checked>
                                    <span class="small">{{ fieldLabels[field] ?? field }}</span>
                                </label>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </aside>

            <main class="col-lg-9 order-1 order-lg-2">
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 20%;">Поле</th>
                                {% for subject in subjects %}
                                    <th>{{ _self.subject_head(subject) }}</th>
                                {% endfor %}
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in comparison.rows %}
                                <tr data-compare-filter-target="row" data-field="{{ row.field }}"
                                    {% if row.isDifferent %}class="table-warning"{% endif %}>
                                    <th scope="row">{{ fieldLabels[row.field] ?? row.field }}</th>
                                    {% for value in row.values %}
                                        <td>{{ _self.format_value(row.field, value) }}</td>
                                    {% endfor %}
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {# ==== Время высыхания — per-interval сравнение.
                       Одна таблица на каждый интервал (Сухой на отлип / Полное отверждение /
                       Мин перекрытия / Макс перекрытия + env → base ветки). Строки =
                       purchases, колонки = union температур всех subject'ов. Столбцы,
                       где значения различаются между subject'ами, подсвечены table-warning
                       (per-cell diff, а не whole-object). ==== #}
                <h2 class="h4 mt-5 mb-3">Время высыхания</h2>
                {% set compareMatrix = coating_compare_matrix(subjects) %}
                {% for section in compareMatrix %}
                    <div class="card mb-3">
                        <div class="card-header py-2 fw-semibold">
                            {{ section.label }}
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="text-muted fw-normal">Покрытие</th>
                                        {% for t in section.columns %}
                                            <th class="text-center text-nowrap {% if section.diffColumns[t] is defined %}table-warning{% endif %}">
                                                {{ t > 0 ? '+' ~ t : t }} °C
                                            </th>
                                        {% endfor %}
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for row in section.rows %}
                                        <tr>
                                            <th scope="row" class="fw-normal">
                                                {{ _self.subject_head(row.subject) }}
                                            </th>
                                            {% for t in section.columns %}
                                                {% set cell = row.values[t] %}
                                                <td class="text-center text-nowrap
                                                    {% if section.diffColumns[t] is defined %}table-warning{% endif %}
                                                    {% if cell.is_calculated %}text-muted fst-italic{% endif %}">
                                                    {% if cell.minutes is null %}
                                                        <span class="text-muted">—</span>
                                                    {% elseif cell.minutes == 0 %}
                                                        <i class="bi bi-infinity" title="без ограничения"></i>
                                                    {% else %}
                                                        {{ cell.minutes|duration_minutes_short }}
                                                    {% endif %}
                                                </td>
                                            {% endfor %}
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <p class="text-muted">Нет данных по времени высыхания у сравниваемых покрытий.</p>
                {% endfor %}
                <p class="text-muted small">
                    Жёлтым выделены столбцы, где значения различаются между покрытиями.
                    Курсив — рассчитано интерполяцией. «—» — вне диапазона / нет данных.
                </p>
            </main>
        </div>
    </div>
{% endblock %}

{# Per-field форматтер для скалярных полей. #}
{% macro format_value(field, value) %}
    {% if value is null %}
        <span class="text-muted">—</span>
    {% else %}
        {{ value }}
    {% endif %}
{% endmacro %}
