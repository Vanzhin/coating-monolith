{% extends '/cabinet/index.html.twig' %}
{% import 'admin/coating/coating/_recoating_pair_table.html.twig' as pairTable %}

{% block title %}{{ parent() }} | Покрытия{% endblock %}

{% block content %}
    {% set canEdit = is_granted('ROLE_ADMIN') %}
    {# Карта {key_lower => "Русское название (ISO)"} для подписей base-узлов в модалке покрытия. #}
    {% set baseLabels = {} %}
    {% for b in coatingBases ?? [] %}
        {% set baseLabels = baseLabels|merge({(b.value|lower): b.title ~ ' (' ~ b.value ~ ')'}) %}
    {% endfor %}

    <div class="col-lg-10 mx-auto p-2 p-md-4 py-md-5"
         data-controller="compare-tray"
         data-compare-tray-storage-key-value="compare:Coating"
         data-compare-tray-compare-url-value="{{ path('app_cabinet_coating_coating_compare') }}"
         data-compare-tray-max-value="4">
        <div class="d-flex flex-md-row align-items-center justify-content-between mb-3">
            <h2 class="text-body-emphasis mb-0">Покрытия</h2>
            {% if canEdit %}
                <a href="{{ path('app_cabinet_coating_coating_create') }}"
                   class="btn btn-outline-success" title="Добавить">
                    <i class="bi bi-plus-lg"></i>
                </a>
            {% endif %}
        </div>

        <form method="get" action="{{ path('app_cabinet_coating_coating_list') }}" class="mb-3">
            <div class="input-group input-group-lg mb-3">
                <input type="search" name="search" value="{{ search }}"
                       class="form-control"
                       placeholder="По названию и описанию (3-50 символов)"
                       minlength="3" maxlength="50" autocomplete="off">
                <button type="submit" class="btn btn-primary">Найти</button>
            </div>

            {# Range-фасет активен, если хоть одна граница задана. #}
            {% set appMinTempActive = appMinTempFrom is not null or appMinTempTo is not null %}
            {% set volumeSolidActive = volumeSolidFrom is not null or volumeSolidTo is not null %}
            {% set activeFacetsCount = selectedManufacturerIds.count
                + (appMinTempActive ? 1 : 0)
                + (volumeSolidActive ? 1 : 0) %}

            <div class="d-flex justify-content-between align-items-center mb-2">
                <button class="btn btn-outline-secondary btn-sm" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#advancedFilter"
                        aria-expanded="{{ activeFacetsCount > 0 ? 'true' : 'false' }}"
                        aria-controls="advancedFilter">
                    <i class="bi bi-funnel"></i> Расширенный поиск
                    {% if activeFacetsCount > 0 %}
                        <span class="badge bg-primary ms-1">{{ activeFacetsCount }}</span>
                    {% endif %}
                </button>

                {% if search or activeFacetsCount > 0 %}
                    <a href="{{ path('app_cabinet_coating_coating_list') }}" class="text-muted small">
                        Сбросить
                    </a>
                {% endif %}
            </div>

            <div class="collapse {% if activeFacetsCount > 0 %} show {% endif %}" id="advancedFilter">
                <div class="card card-body">
                    {# === Мин температура нанесения — чипы-пресеты === #}
                    <div class="pb-3 mb-3 border-bottom" data-controller="range-filter">
                        <div class="d-flex justify-content-between align-items-baseline mb-2">
                            <label class="form-label fw-semibold mb-0">Мин температура нанесения</label>
                            <span class="text-muted small">°C</span>
                        </div>

                        <input type="hidden" name="appMinTempFrom" value="{{ appMinTempFrom }}"
                               data-range-filter-target="fromInput">
                        <input type="hidden" name="appMinTempTo" value="{{ appMinTempTo }}"
                               data-range-filter-target="toInput">

                        <div class="d-flex flex-wrap gap-1">
                            <button type="button" class="btn btn-sm {% if not appMinTempActive %}btn-secondary{% else %}btn-outline-secondary{% endif %}"
                                    data-action="click->range-filter#reset">Любая</button>
                            {% for p in appMinTempPresets %}
                                {% set active = appMinTempFrom == p.from and appMinTempTo == p.to %}
                                <button type="button"
                                        class="btn btn-sm {% if active %}btn-primary{% else %}btn-outline-primary{% endif %}"
                                        data-action="click->range-filter#preset"
                                        data-from="{{ p.from }}" data-to="{{ p.to }}">
                                    {{ p.label }}
                                </button>
                            {% endfor %}
                        </div>
                    </div>

                    {# === Сухой остаток — чипы без слайдера === #}
                    <div class="pb-3 mb-3 border-bottom" data-controller="range-filter">
                        <div class="d-flex justify-content-between align-items-baseline mb-2">
                            <label class="form-label fw-semibold mb-0">Сухой остаток</label>
                            <span class="text-muted small">% об.</span>
                        </div>

                        <input type="hidden" name="volumeSolidFrom" value="{{ volumeSolidFrom }}"
                               data-range-filter-target="fromInput">
                        <input type="hidden" name="volumeSolidTo" value="{{ volumeSolidTo }}"
                               data-range-filter-target="toInput">

                        <div class="d-flex flex-wrap gap-1">
                            <button type="button" class="btn btn-sm {% if not volumeSolidActive %}btn-secondary{% else %}btn-outline-secondary{% endif %}"
                                    data-action="click->range-filter#reset">Любой</button>
                            {% for p in volumeSolidPresets %}
                                {% set active = volumeSolidFrom == p.from and volumeSolidTo == p.to %}
                                <button type="button"
                                        class="btn btn-sm {% if active %}btn-primary{% else %}btn-outline-primary{% endif %}"
                                        data-action="click->range-filter#preset"
                                        data-from="{{ p.from }}" data-to="{{ p.to }}">
                                    {{ p.label }}
                                </button>
                            {% endfor %}
                        </div>
                    </div>

                    {# === Производитель — чекбоксы === #}
                    <div>
                        <label class="form-label fw-semibold mb-2">Производитель</label>
                        <div class="row">
                            {% for m in manufacturers %}
                                <div class="col-md-6">
                                    <div class="form-check">
                                        <input type="checkbox"
                                               class="form-check-input"
                                               name="manufacturerIds[]"
                                               value="{{ m.id }}"
                                               id="manufacturer-{{ m.id }}"
                                               {% if m.id in selectedManufacturerIds.list %} checked {% endif %}>
                                        <label class="form-check-label" for="manufacturer-{{ m.id }}">
                                            {{ m.title }}
                                        </label>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </form>

        {% if error %}
            <div class="alert alert-warning" role="alert">{{ error }}</div>
        {% endif %}

        {# Список и пейджер идут наравне с формой поиска: без горизонтальных
           отступов (иначе card ширины уже, чем input) и минимальный
           вертикальный отступ сверху для дыхания. #}
        <div class="mt-3">
            {% if result.coatings %}
                <div class="list-group w-100 shadow-sm rounded">
                    {% for coating in result.coatings %}
                        <div class="list-group-item d-flex align-items-start gap-2 gap-md-3 px-2 px-md-3 py-3">
                            <div class="form-check flex-shrink-0 m-0 mt-1">
                                <input type="checkbox" class="form-check-input m-0"
                                       data-compare-id="{{ coating.id }}"
                                       data-action="change->compare-tray#toggle"
                                       aria-label="Добавить к сравнению">
                            </div>
                            <div class="flex-grow-1 overflow-hidden"
                                 style="cursor: pointer;"
                                 data-bs-toggle="modal"
                                 data-bs-target="#coatingPreview-{{ coating.id }}">
                                {# text-wrap + word-break: title переносится на 2 строки
                                   вместо уродливого truncate'a на mobile. #}
                                <h6 class="mb-1 fw-semibold" style="word-break: break-word;">{{ coating.title }}</h6>
                                <p class="mb-1 small text-muted"
                                   style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                    {{ coating.description }}
                                </p>
                                {% if coating.tags|length > 0 %}
                                    <div class="d-flex flex-wrap gap-1">
                                        {% for tag in coating.tags %}
                                            <span class="badge text-bg-light border fw-normal">{{ tag.title }}</span>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            {% if canEdit %}
                                {# На <md кнопки выстраиваются в столбик (≈38px шириной
                                   вместо ≈130px рядом) — высвобождает место под title+
                                   description+chips на iPhone SE (375px). #}
                                <div class="d-flex gap-1 gap-md-2 flex-shrink-0 flex-column flex-md-row">
                                    {% include '/components/edit_delete.html.twig'
                                        with {
                                        'edit': 'app_cabinet_coating_coating_update',
                                        'delete':'app_cabinet_coating_coating_delete',
                                        'duplicate': 'app_cabinet_coating_coating_create',
                                        'id': coating.id,
                                        'title': coating.title,
                                        'name': "покрытие"
                                    } %}
                                </div>
                            {% endif %}
                        </div>

                        <div class="modal fade" id="coatingPreview-{{ coating.id }}" tabindex="-1"
                             aria-labelledby="coatingPreviewLabel-{{ coating.id }}" aria-hidden="true">
                            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <div>
                                            <h5 class="modal-title mb-0" id="coatingPreviewLabel-{{ coating.id }}">
                                                {{ coating.title }}
                                            </h5>
                                            <small class="text-muted">{{ coating.manufacturer.title }}</small>
                                        </div>
                                        <button type="button" class="btn-close"
                                                data-bs-dismiss="modal" aria-label="Закрыть"></button>
                                    </div>
                                    <div class="modal-body">
                                        {% if coating.tags|length > 0 %}
                                            <div class="mb-3">
                                                {% for tag in coating.tags %}
                                                    <span class="badge text-bg-light border me-1">{{ tag.title }}</span>
                                                {% endfor %}
                                            </div>
                                        {% endif %}

                                        {% if coating.description %}
                                            <p class="text-body-secondary mb-4">{{ coating.description }}</p>
                                        {% endif %}

                                        <h6 class="mb-2 mt-1">Основные характеристики</h6>
                                        <table class="table table-sm mb-4">
                                            <tbody>
                                                {% set baseEnum = coating.baseEnum %}
                                                {% if baseEnum %}
                                                    <tr>
                                                        <th scope="row" class="text-muted fw-normal" style="width: 60%;">Тип ЛКМ (основание)</th>
                                                        <td>
                                                            {{ baseEnum.title }}
                                                            <span class="text-muted">
                                                                ({{ baseEnum.iso }}{% if baseEnum.gost|length > 0 %} / {{ baseEnum.gost|join(', ') }}{% endif %})
                                                            </span>
                                                        </td>
                                                    </tr>
                                                {% endif %}
                                                <tr>
                                                    <th scope="row" class="text-muted fw-normal" style="width: 60%;">Сухой остаток</th>
                                                    <td>{{ coating.volumeSolid }} об. %</td>
                                                </tr>
                                                <tr>
                                                    <th scope="row" class="text-muted fw-normal">Плотность</th>
                                                    <td>{{ coating.massDensity }} кг/л</td>
                                                </tr>
                                                <tr>
                                                    <th scope="row" class="text-muted fw-normal">Толщина сухой плёнки</th>
                                                    <td>
                                                        {{ coating.dftRange.min }}–{{ coating.dftRange.max }} мкм
                                                        <span class="text-muted">(целевая {{ coating.dftRange.tds_dft }})</span>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <th scope="row" class="text-muted fw-normal">Рабочий диапазон температур</th>
                                                    <td>{{ coating.applicationMinTemp }} … {{ coating.dryingMaxTemp }} °C</td>
                                                </tr>
                                                <tr>
                                                    <th scope="row" class="text-muted fw-normal">Упаковка</th>
                                                    <td>{{ coating.pack }} л</td>
                                                </tr>
                                                {% if coating.thinner %}
                                                    <tr>
                                                        <th scope="row" class="text-muted fw-normal">Разбавитель</th>
                                                        <td>{{ coating.thinner }}</td>
                                                    </tr>
                                                {% endif %}
                                            </tbody>
                                        </table>

                                        {# ==== Время высыхания — matrix (см. CoatingTimeMatrixBuilder) ==== #}
                                        {% set matrix = coating_time_matrix(coating) %}
                                        <h6 class="mb-2 mt-1">Время высыхания</h6>
                                        <div class="table-responsive">
                                        <table class="table table-sm table-bordered align-middle mb-2">
                                            <thead class="table-light">
                                                <tr>
                                                    <th class="text-muted fw-normal">Температура поверхности</th>
                                                    {% for t in matrix.columns %}
                                                        <th class="text-center text-nowrap">{{ t > 0 ? '+' ~ t : t }} °C</th>
                                                    {% endfor %}
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {% for row in matrix.rows %}
                                                    <tr>
                                                        <th scope="row" class="fw-normal">{{ row.label }}</th>
                                                        {% for t in matrix.columns %}
                                                            {% set cell = row.values[t] %}
                                                            <td class="text-center text-nowrap {% if cell.is_calculated %}text-muted fst-italic{% endif %}">
                                                                {% if cell.minutes is null %}
                                                                    <span class="text-muted">—</span>
                                                                {% elseif cell.minutes == 0 %}
                                                                    <i class="bi bi-infinity" title="без ограничения"></i>
                                                                {% else %}
                                                                    {{ cell.minutes|duration_minutes_short }}
                                                                {% endif %}
                                                            </td>
                                                        {% endfor %}
                                                    </tr>
                                                {% endfor %}
                                            </tbody>
                                        </table>
                                        </div>
                                        <p class="text-muted small mb-0">
                                            Курсивом — рассчитанные интерполяцией значения.
                                            «—» — данные отсутствуют или вне определённого диапазона.
                                            {% if coating.maxRecoatingInterval is null %}
                                                Верхняя граница интервала перекрытия не задана.
                                            {% endif %}
                                        </p>
                                    </div>
                                    <div class="modal-footer">
                                        {% if canEdit %}
                                            <a href="{{ path('app_cabinet_coating_coating_update', {id: coating.id}) }}"
                                               class="btn btn-outline-primary">
                                                <i class="bi bi-pencil"></i> Редактировать
                                            </a>
                                        {% endif %}
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
                {% if canEdit %}
                    {% include 'components/delete_modal.html.twig' with {'delete':'app_cabinet_coating_coating_delete'} %}
                {% endif %}

                {% include 'components/pager.html.twig' with {'pager': result.pager} %}
            {% else %}
                {% if search %}
                    {# Специфичное сообщение для поискового empty-state: показываем
                       исходный запрос + подсказку. На multi-word fuzzy не отрабатывает
                       по дизайну (см. CoatingRepository::findByFilter, Option C).
                       Плашка не исчезает автоматически (см. base.html.twig auto-dismiss
                       сужен до .flash-messages .alert). #}
                    <div class="alert alert-warning text-center mt-3 py-4 shadow-sm" role="status">
                        <i class="bi bi-search fs-1 d-block mb-2 text-secondary"></i>
                        <h5 class="alert-heading mb-2">Ничего не найдено</h5>
                        <p class="mb-2">
                            По запросу «<strong>{{ search }}</strong>» совпадений нет.
                        </p>
                        <p class="small text-muted mb-0">
                            Каждое слово должно встретиться в названии, описании или тегах.
                            Попробуйте сократить запрос или использовать другие слова.
                        </p>
                    </div>
                {% else %}
                    {% include 'components/empty.html.twig' %}
                {% endif %}
            {% endif %}
        </div>

        <div class="position-fixed bottom-0 start-50 translate-middle-x mb-3 d-none"
             style="z-index: 1080;"
             data-compare-tray-target="bar">
            <div class="card shadow">
                <div class="card-body py-2 px-3 d-flex align-items-center gap-3">
                    <span class="small">К сравнению: <strong data-compare-tray-target="count">0</strong></span>
                    <button type="button" class="btn btn-sm btn-primary"
                            data-action="click->compare-tray#open"
                            data-compare-tray-target="openBtn" disabled>
                        Сравнить
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary"
                            data-action="click->compare-tray#clear">
                        Очистить
                    </button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
