                                    <option value="dry_heat" {% if thermEnvEffective == 'dry_heat' %}selected{% endif %}>Сухое тепло</option>
                                    <option value="immersion" {% if thermEnvEffective == 'immersion' %}selected{% endif %}>Погружение</option>
                                </select>
