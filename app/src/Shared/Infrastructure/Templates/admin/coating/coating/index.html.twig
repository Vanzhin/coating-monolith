                                        <input type="checkbox" class="form-check-input"
                                               name="manufacturerIds[]" value="{{ m.id }}"
                                               id="mfOff-{{ m.id }}"
                                               {% if m.id in selectedManufacturerIds.list %}checked{% endif %}>
                                        <label class="form-check-label" for="mfOff-{{ m.id }}">{{ m.title }}</label>
