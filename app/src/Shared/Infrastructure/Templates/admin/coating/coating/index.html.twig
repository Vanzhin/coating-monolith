{% extends '/cabinet/index.html.twig' %}
{% import 'admin/coating/coating/_recoating_pair_table.html.twig' as pairTable %}

{% block title %}{{ parent() }} | Покрытия{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Scrollable часть chip-row на мобильной: горизонтальный скролл без
           видимого скроллбара, dropdown'ы всё ещё раскрываются. */
        @media (max-width: 767.98px) {
            .chip-scroll {
                overflow-x: auto;
                overflow-y: visible;
                scrollbar-width: none;
                -webkit-overflow-scrolling: touch;
            }
            .chip-scroll::-webkit-scrollbar { display: none; }
        }
        /* На десктопе делаем pinned+scroll обёртки «прозрачными» (display: contents)
           — их дети становятся прямыми потомками .chip-row и оборачиваются одной
           цепочкой в flex-wrap. Иначе scroll-блок оборачивается внутри себя,
           а pinned-блок центрируется вертикально относительно него — визуально
           первые два чипа оказываются посередине обёрнутого второго блока. */
        @media (min-width: 768px) {
            .chip-row {
                flex-wrap: wrap;
            }
            .chip-row-pinned,
            .chip-scroll {
                display: contents;
            }
        }
    </style>
{% endblock %}



{% block content %}
    {% set canEdit = is_granted('ROLE_ADMIN') %}
    {% set selectedTagIdList = selectedTagIds.list %}
    {# Карта {key_lower => "Русское название (ISO)"} для подписей base-узлов в модалке покрытия. #}
    {% set baseLabels = {} %}
    {% for b in coatingBases ?? [] %}
        {% set baseLabels = baseLabels|merge({(b.value|lower): b.title ~ ' (' ~ b.value ~ ')'}) %}
    {% endfor %}

    {# id'ы активных tag-фильтров — раз собрать для переиспользования (проверки
       on/off, toggle-url'ы, empty-state chip-row'а внутри offcanvas'a). #}
    {% set selectedTagIdList = selectedTags|map(t => t.id) %}

    <div data-controller="compare-tray"
         data-compare-tray-storage-key-value="compare:Coating"
         data-compare-tray-compare-url-value="{{ path('app_cabinet_coating_coating_compare') }}"
         data-compare-tray-max-value="4">
    {% embed 'components/list_page.html.twig' with {
        title: 'Покрытия',
        create_route: 'app_cabinet_coating_coating_create',
        can_edit: canEdit,
        is_empty: result.coatings is empty,
    } %}
    {% block above_list %}
        <form method="get" action="{{ path('app_cabinet_coating_coating_list') }}" class="mb-3">
            <div class="input-group input-group-lg mb-3">
                {# Строка поиска — только текст. Активные фасеты (производитель /
                   ranges / thermal / теги) в chip-row показаны как value-чипы-ссылки,
                   не как form-input'ы. Чтобы они не терялись при сабмите этой
                   формы (через search-input, apply-кнопки в dropdown'ах пустых
                   фасетов, range-preset auto-submit) — рендерим их как hidden ниже. #}
                <input type="search" name="search" value="{{ search }}"
                       class="form-control"
                       placeholder="По названию и описанию (3-50 символов)"
                       minlength="3" maxlength="50" autocomplete="off">
                <button type="submit" class="btn btn-primary">Найти</button>
            </div>

            {# Preserve-state: hidden input'ы активных фасетов, чтобы submit формы
               не сбрасывал их. Рендерим только для активных — у пустых свои
               dropdown'ы с form-контролами. #}
            {% for id in selectedManufacturerIds.list %}
                <input type="hidden" name="manufacturerIds[]" value="{{ id }}">
            {% endfor %}
            {% if appMinTempFrom is not null %}
                <input type="hidden" name="appMinTempFrom" value="{{ appMinTempFrom }}">
            {% endif %}
            {% if appMinTempTo is not null %}
                <input type="hidden" name="appMinTempTo" value="{{ appMinTempTo }}">
            {% endif %}
            {% if volumeSolidFrom is not null %}
                <input type="hidden" name="volumeSolidFrom" value="{{ volumeSolidFrom }}">
            {% endif %}
            {% if volumeSolidTo is not null %}
                <input type="hidden" name="volumeSolidTo" value="{{ volumeSolidTo }}">
            {% endif %}
            {% if thermTemp is not null %}
                <input type="hidden" name="thermTemp" value="{{ thermTemp }}">
            {% endif %}
            {% if thermEnv %}
                <input type="hidden" name="thermEnv" value="{{ thermEnv }}">
            {% endif %}
            {% if thermIncludingPeak %}
                <input type="hidden" name="thermPeak" value="1">
            {% endif %}
            {% for tag in selectedTags %}
                <input type="hidden" name="tagIds[]" value="{{ tag.id }}">
            {% endfor %}
            {% if sort != constant('App\\Coatings\\Domain\\Repository\\CoatingSort::DEFAULT') %}
                <input type="hidden" name="sort" value="{{ sort.value }}">
            {% endif %}


            {# Активные состояния фасетов: используются в лейблах и стилях dropdown-чипов. #}
            {% set appMinTempActive = appMinTempFrom is not null or appMinTempTo is not null %}
            {% set volumeSolidActive = volumeSolidFrom is not null or volumeSolidTo is not null %}
            {% set thermalActive = thermTemp is not null and thermEnv %}
            {% set activeFacetsCount = selectedManufacturerIds.count
                + (appMinTempActive ? 1 : 0)
                + (volumeSolidActive ? 1 : 0)
                + (thermalActive ? 1 : 0)
                + selectedTags|length %}

            {# === Горизонтальный ряд chip-dropdown'ов ===
                 Порядок: «Все фильтры» первой, затем per-фасет чипы.
                 Каждый facet-чип:
                   - Пустое состояние: `[Label ▾]` (btn-outline-secondary + dropdown).
                   - Активное состояние: `[Label: значения ▾][×]` — btn-group из
                     двух кнопок primary. Левая (dropdown) — редактировать. Правая
                     (×) — reset только этого фасета через URL.
                 `data-bs-auto-close="outside"` — не закрывать dropdown при
                 клике по чекбоксу/input'у внутри. #}

            {# Компактные строки-summary для активных фасетов (обрезаем длинные списки). #}
            {% set mfNames = manufacturers|filter(m => m.id in selectedManufacturerIds.list)|map(m => m.title) %}
            {% set mfSummary = mfNames|length > 0 ? mfNames|join(', ') : null %}
            {% set appMinSummary = appMinTempActive
                ? (appMinTempFrom is not null and appMinTempTo is not null ? appMinTempFrom ~ '…' ~ appMinTempTo ~ '°C'
                   : (appMinTempFrom is not null ? '≥ ' ~ appMinTempFrom ~ '°C' : '≤ ' ~ appMinTempTo ~ '°C'))
                : null %}
            {% set vsSummary = volumeSolidActive
                ? (volumeSolidFrom is not null and volumeSolidTo is not null ? volumeSolidFrom ~ '…' ~ volumeSolidTo ~ '%'
                   : (volumeSolidFrom is not null ? '≥ ' ~ volumeSolidFrom ~ '%' : '≤ ' ~ volumeSolidTo ~ '%'))
                : null %}
            {% set thSummary = thermalActive
                ? thermTemp ~ '°C ' ~ (thermEnv == 'immersion' ? 'погр.' : 'сух.') ~ (thermIncludingPeak ? ' +пик' : '')
                : null %}
            {% set tagSummary = selectedTags|length > 0 ? selectedTags|map(t => t.title)|join(', ') : null %}

            {# Reset-URL'ы каждого фасета — для × кнопок. #}
            {% set mfResetUrl = path('app_cabinet_coating_coating_list', app.request.query.all|merge({manufacturerIds: [], page: null})|filter(v => v is not null)) %}
            {% set appMinResetUrl = path('app_cabinet_coating_coating_list', app.request.query.all|merge({appMinTempFrom: null, appMinTempTo: null, page: null})|filter(v => v is not null)) %}
            {% set vsResetUrl = path('app_cabinet_coating_coating_list', app.request.query.all|merge({volumeSolidFrom: null, volumeSolidTo: null, page: null})|filter(v => v is not null)) %}
            {% set thResetUrl = path('app_cabinet_coating_coating_list', app.request.query.all|merge({thermTemp: null, thermEnv: null, thermPeak: null, page: null})|filter(v => v is not null)) %}
            {% set tagResetUrl = path('app_cabinet_coating_coating_list', app.request.query.all|merge({tagIds: [], page: null})|filter(v => v is not null)) %}

            {# === Chip-row: transform-pattern ===
                 - Фасет пуст → `[Фасет ▾]` chip-dropdown для выбора.
                 - Фасет активен → chip-dropdown ПРОПАДАЕТ, вместо него value-чип(ы).
                   Multi (производитель / теги): по одному чипу на значение.
                   Single (range / thermal): один сводный чип.
                 - × на value-чипе снимает это значение; когда снимут последнее —
                   pустой chip-dropdown возвращается сам собой (следующий рендер).
                 - Добавить второе значение в multi после первого — через offcanvas
                   «Все фильтры» (там все секции + Tagify + сохраняется выбор). #}
            {# Chip-row: mvideo-mobile-pattern. На мобильной (<md) sort+all-filters
               остаются фиксированно слева (только иконки, без слов), остальные
               chip'ы скроллятся горизонтально в правом блоке. На md+ обычный
               flex-wrap с полными текстами. #}
            <div class="d-flex align-items-center gap-2 mb-3 chip-row">
                <div class="d-flex gap-2 flex-shrink-0 chip-row-pinned">

                {# --- Сортировка — самая первая chip'а (mvideo-style).
                     Не dropdown в стиле фасета, а <a href>-ссылки со sort=… в URL;
                     активное значение — не DEFAULT (primary), иначе outline-secondary.
                     Смена на DEFAULT удаляет sort из URL (короткий query). #}
                {% set defaultSort = constant('App\\Coatings\\Domain\\Repository\\CoatingSort::DEFAULT') %}
                {% set sortActive = sort != defaultSort %}
                <div class="dropdown">
                    <button type="button"
                            class="btn btn-sm {{ sortActive ? 'btn-primary' : 'btn-outline-secondary' }} dropdown-toggle"
                            data-bs-toggle="dropdown" aria-expanded="false"
                            aria-label="Сортировка">
                        <i class="bi bi-sort-down"></i><span class="d-none d-md-inline"> {{ sortActive ? sort.label : 'Сортировка' }}</span>
                    </button>
                    <ul class="dropdown-menu">
                        {% for opt in sortOptions %}
                            {% set q = opt == defaultSort
                                ? app.request.query.all|merge({sort: null, page: null})|filter(v => v is not null)
                                : app.request.query.all|merge({sort: opt.value, page: null})|filter(v => v is not null) %}
                            <li>
                                <a class="dropdown-item {% if sort == opt %}active{% endif %}"
                                   href="{{ path('app_cabinet_coating_coating_list', q) }}">
                                    {{ opt.label }}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </div>

                {# --- Все фильтры (offcanvas) --- #}
                <button type="button"
                        class="btn btn-sm {{ activeFacetsCount > 0 ? 'btn-primary' : 'btn-outline-secondary' }} position-relative"
                        data-bs-toggle="offcanvas" data-bs-target="#allFiltersOffcanvas"
                        aria-controls="allFiltersOffcanvas"
                        aria-label="Все фильтры">
                    <i class="bi bi-sliders"></i><span class="d-none d-md-inline"> Все фильтры</span>
                    {% if activeFacetsCount > 0 %}
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill text-bg-danger" style="font-size: 0.65rem;">
                            {{ activeFacetsCount }}
                        </span>
                    {% endif %}
                </button>
                </div>

                {# Скроллируемая часть: остальные chip'ы. На md+ — обычный flex-wrap. #}
                <div class="d-flex align-items-center gap-2 flex-nowrap flex-md-wrap chip-scroll flex-grow-1">

                {# --- Производитель (multi) --- #}
                {% if selectedManufacturerIds.count == 0 %}
                    <div class="dropdown">
                        <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            Производитель
                        </button>
                        <div class="dropdown-menu p-3" style="min-width: 260px; max-height: 400px; overflow-y: auto;">
                            {% for m in manufacturers %}
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input"
                                           name="manufacturerIds[]" value="{{ m.id }}"
                                           id="mf-{{ m.id }}">
                                    <label class="form-check-label" for="mf-{{ m.id }}">{{ m.title }}</label>
                                </div>
                            {% endfor %}
                            <hr class="my-2">
                            <button type="submit" class="btn btn-sm btn-primary w-100">Применить</button>
                        </div>
                    </div>
                {% else %}
                    {% for m in manufacturers|filter(m => m.id in selectedManufacturerIds.list) %}
                        {% set idsAfterRemove = selectedManufacturerIds.list|filter(id => id != m.id) %}
                        {% set removeUrl = path('app_cabinet_coating_coating_list', app.request.query.all|merge({manufacturerIds: idsAfterRemove, page: null})|filter(v => v is not null)) %}
                        <a href="{{ removeUrl }}"
                           class="btn btn-sm btn-primary d-inline-flex align-items-center gap-1"
                           title="Убрать «{{ m.title }}» из фильтра">
                            {{ m.title }} <i class="bi bi-x-lg"></i>
                        </a>
                    {% endfor %}
                {% endif %}

                {# --- Мин Т нанесения (single, range-пресеты) --- #}
                {% if not appMinTempActive %}
                    <div class="dropdown">
                        <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            Мин Т нанесения
                        </button>
                        <div class="dropdown-menu p-3" style="min-width: 260px;" data-controller="range-filter">
                            <input type="hidden" name="appMinTempFrom" value=""
                                   data-range-filter-target="fromInput">
                            <input type="hidden" name="appMinTempTo" value=""
                                   data-range-filter-target="toInput">
                            <div class="d-flex flex-wrap gap-1">
                                <button type="button" class="btn btn-sm btn-secondary"
                                        data-action="click->range-filter#reset">Любая</button>
                                {% for p in appMinTempPresets %}
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            data-action="click->range-filter#preset"
                                            data-from="{{ p.from }}" data-to="{{ p.to }}">
                                        {{ p.label }}
                                    </button>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% else %}
                    <a href="{{ appMinResetUrl }}"
                       class="btn btn-sm btn-primary d-inline-flex align-items-center gap-1"
                       title="Убрать фильтр">
                        Мин Т нанесения: {{ appMinSummary }} <i class="bi bi-x-lg"></i>
                    </a>
                {% endif %}

                {# --- Сухой остаток (single) --- #}
                {% if not volumeSolidActive %}
                    <div class="dropdown">
                        <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            Сухой остаток
                        </button>
                        <div class="dropdown-menu p-3" style="min-width: 260px;" data-controller="range-filter">
                            <input type="hidden" name="volumeSolidFrom" value=""
                                   data-range-filter-target="fromInput">
                            <input type="hidden" name="volumeSolidTo" value=""
                                   data-range-filter-target="toInput">
                            <div class="d-flex flex-wrap gap-1">
                                <button type="button" class="btn btn-sm btn-secondary"
                                        data-action="click->range-filter#reset">Любой</button>
                                {% for p in volumeSolidPresets %}
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            data-action="click->range-filter#preset"
                                            data-from="{{ p.from }}" data-to="{{ p.to }}">
                                        {{ p.label }}
                                    </button>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% else %}
                    <a href="{{ vsResetUrl }}"
                       class="btn btn-sm btn-primary d-inline-flex align-items-center gap-1"
                       title="Убрать фильтр">
                        Сухой остаток: {{ vsSummary }} <i class="bi bi-x-lg"></i>
                    </a>
                {% endif %}

                {# --- Температура эксплуатации (single) --- #}
                {% if not thermalActive %}
                    <div class="dropdown">
                        <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            Температура эксплуатации
                        </button>
                        <div class="dropdown-menu p-3" style="min-width: 320px;">
                            <div class="mb-2">
                                <label class="form-label small text-muted mb-1">Температура, °C</label>
                                <input type="number" name="thermTemp" value=""
                                       class="form-control form-control-sm"
                                       min="-100" max="500" step="5" placeholder="напр. 90">
                            </div>
                            <div class="mb-2">
                                <label class="form-label small text-muted mb-1">Среда</label>
                                <select name="thermEnv" class="form-select form-select-sm">
                                    <option value="dry_heat" selected>Сухое тепло</option>
                                    <option value="immersion">Погружение</option>
                                </select>
                            </div>
                            <div class="form-check mb-2">
                                <input type="checkbox" class="form-check-input"
                                       id="thermPeakDd" name="thermPeak" value="1">
                                <label class="form-check-label small" for="thermPeakDd">Включая пиковые нагрузки</label>
                            </div>
                            <button type="submit" class="btn btn-sm btn-primary w-100">Применить</button>
                        </div>
                    </div>
                {% else %}
                    <a href="{{ thResetUrl }}"
                       class="btn btn-sm btn-primary d-inline-flex align-items-center gap-1"
                       title="Убрать фильтр">
                        Работает при {{ thSummary }} <i class="bi bi-x-lg"></i>
                    </a>
                {% endif %}

                {# Теги (multi) полностью в шторке «Все фильтры» — в chip-row
                   их не показываем, чтобы не засорять горизонтальный ряд.
                   Активные теги видны в offcanvas'e (секция «Активные фильтры»
                   сверху + Tagify-input для редактирования). Счётчик активных
                   тегов идёт в общий badge chip'а «Все фильтры». #}
                {% set selectedTagsJson = selectedTags|map(t => {id: t.id, title: t.title})|json_encode %}

                {# «Сбросить всё» вынесен в шторку «Все фильтры» (footer offcanvas'а)
                   — чтобы в chip-row не было лишней текстовой ссылки, не участвующей
                   в паттерне chip'ов. #}
                </div>{# /.chip-scroll #}
            </div>{# /.chip-row #}
        </form>

        {# === Offcanvas «Все фильтры» ===
             Отдельная форма (не вложена в основную) — те же имена полей, что и у чип-
             dropdown'ов, но браузер сериализует ту форму, кнопку submit которой нажал
             пользователь. Search сохраняем hidden, чтобы не потерять при apply. #}
        <div class="offcanvas offcanvas-end" tabindex="-1" id="allFiltersOffcanvas" aria-labelledby="allFiltersOffcanvasLabel">
            <div class="offcanvas-header border-bottom">
                <h5 class="offcanvas-title" id="allFiltersOffcanvasLabel">
                    Фильтры
                    {% if activeFacetsCount > 0 %}
                        <span class="badge text-bg-primary ms-1">{{ activeFacetsCount }}</span>
                    {% endif %}
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Закрыть"></button>
            </div>

            <form method="get" action="{{ path('app_cabinet_coating_coating_list') }}"
                  id="allFiltersForm" class="offcanvas-body d-flex flex-column p-0">
                {# Не терять текстовый поиск при submit шторки. #}
                {% if search %}<input type="hidden" name="search" value="{{ search }}">{% endif %}

                <div class="flex-grow-1 overflow-auto p-3">
                    {# Активные фильтры сверху шторки — как у mvideo, для мгновенного обзора. #}
                    {% if activeFacetsCount > 0 %}
                        <div class="pb-3 mb-3 border-bottom">
                            <div class="small text-muted mb-2">Активные фильтры</div>
                            <div class="d-flex flex-wrap gap-1">
                                {% for tag in selectedTags %}
                                    {% set idsAfterRemove = selectedTagIdList|filter(id => id != tag.id) %}
                                    {% set q = app.request.query.all|merge({tagIds: idsAfterRemove, page: null})|filter(v => v is not null) %}
                                    {# Инлайн чипа (не macro): _self внутри embed'а
                                       ссылается на partial'у components/list_page.html.twig,
                                       где макроса нет. #}
                                    <span class="badge text-bg-{{ tag.type|tag_bootstrap_color }} fw-normal d-inline-flex align-items-center gap-1">
                                        {{ tag.title }}
                                        <a href="{{ path('app_cabinet_coating_coating_list', q) }}"
                                           class="btn-close btn-close-white btn-close-sm"
                                           title="Убрать «{{ tag.title }}» из фильтра"
                                           aria-label="Убрать из фильтра"></a>
                                    </span>
                                {% endfor %}
                                {% for m in manufacturers|filter(m => m.id in selectedManufacturerIds.list) %}
                                    {% set mfIdsAfterRemove = selectedManufacturerIds.list|filter(id => id != m.id) %}
                                    {% set q = app.request.query.all|merge({manufacturerIds: mfIdsAfterRemove, page: null})|filter(v => v is not null) %}
                                    <span class="badge text-bg-secondary fw-normal d-inline-flex align-items-center gap-1 py-1 px-2">
                                        {{ m.title }}
                                        <a href="{{ path('app_cabinet_coating_coating_list', q) }}"
                                           class="btn-close btn-close-white btn-close-sm ms-1"
                                           aria-label="Убрать"></a>
                                    </span>
                                {% endfor %}
                                {% if appMinTempActive %}
                                    {% set q = app.request.query.all|merge({appMinTempFrom: null, appMinTempTo: null, page: null})|filter(v => v is not null) %}
                                    <span class="badge text-bg-secondary fw-normal d-inline-flex align-items-center gap-1 py-1 px-2">
                                        Мин Т: {{ appMinTempFrom is not null ? appMinTempFrom : '−∞' }}…{{ appMinTempTo is not null ? appMinTempTo : '+∞' }} °C
                                        <a href="{{ path('app_cabinet_coating_coating_list', q) }}"
                                           class="btn-close btn-close-white btn-close-sm ms-1" aria-label="Убрать"></a>
                                    </span>
                                {% endif %}
                                {% if volumeSolidActive %}
                                    {% set q = app.request.query.all|merge({volumeSolidFrom: null, volumeSolidTo: null, page: null})|filter(v => v is not null) %}
                                    <span class="badge text-bg-secondary fw-normal d-inline-flex align-items-center gap-1 py-1 px-2">
                                        Сухой остаток: {{ volumeSolidFrom is not null ? volumeSolidFrom : '−∞' }}…{{ volumeSolidTo is not null ? volumeSolidTo : '+∞' }} %
                                        <a href="{{ path('app_cabinet_coating_coating_list', q) }}"
                                           class="btn-close btn-close-white btn-close-sm ms-1" aria-label="Убрать"></a>
                                    </span>
                                {% endif %}
                                {% if thermalActive %}
                                    {% set q = app.request.query.all|merge({thermTemp: null, thermEnv: null, thermPeak: null, page: null})|filter(v => v is not null) %}
                                    <span class="badge text-bg-secondary fw-normal d-inline-flex align-items-center gap-1 py-1 px-2">
                                        Работает при {{ thermTemp }} °C ({{ thermEnv == 'immersion' ? 'погр.' : 'сух.' }}{{ thermIncludingPeak ? ' +пик' : '' }})
                                        <a href="{{ path('app_cabinet_coating_coating_list', q) }}"
                                           class="btn-close btn-close-white btn-close-sm ms-1" aria-label="Убрать"></a>
                                    </span>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}

                    {# === Секция: Мин Т нанесения === #}
                    <div class="pb-3 mb-3 border-bottom" data-controller="range-filter">
                        <h6 class="fw-semibold mb-2">Мин температура нанесения <span class="text-muted small fw-normal">°C</span></h6>
                        <input type="hidden" name="appMinTempFrom" value="{{ appMinTempFrom }}"
                               data-range-filter-target="fromInput">
                        <input type="hidden" name="appMinTempTo" value="{{ appMinTempTo }}"
                               data-range-filter-target="toInput">
                        <div class="d-flex flex-wrap gap-1">
                            <button type="button" class="btn btn-sm {% if not appMinTempActive %}btn-secondary{% else %}btn-outline-secondary{% endif %}"
                                    data-action="click->range-filter#reset">Любая</button>
                            {% for p in appMinTempPresets %}
                                {% set active = appMinTempFrom == p.from and appMinTempTo == p.to %}
                                <button type="button" class="btn btn-sm {% if active %}btn-primary{% else %}btn-outline-primary{% endif %}"
                                        data-action="click->range-filter#preset"
                                        data-from="{{ p.from }}" data-to="{{ p.to }}">
                                    {{ p.label }}
                                </button>
                            {% endfor %}
                        </div>
                    </div>

                    {# === Секция: Сухой остаток === #}
                    <div class="pb-3 mb-3 border-bottom" data-controller="range-filter">
                        <h6 class="fw-semibold mb-2">Сухой остаток <span class="text-muted small fw-normal">% об.</span></h6>
                        <input type="hidden" name="volumeSolidFrom" value="{{ volumeSolidFrom }}"
                               data-range-filter-target="fromInput">
                        <input type="hidden" name="volumeSolidTo" value="{{ volumeSolidTo }}"
                               data-range-filter-target="toInput">
                        <div class="d-flex flex-wrap gap-1">
                            <button type="button" class="btn btn-sm {% if not volumeSolidActive %}btn-secondary{% else %}btn-outline-secondary{% endif %}"
                                    data-action="click->range-filter#reset">Любой</button>
                            {% for p in volumeSolidPresets %}
                                {% set active = volumeSolidFrom == p.from and volumeSolidTo == p.to %}
                                <button type="button" class="btn btn-sm {% if active %}btn-primary{% else %}btn-outline-primary{% endif %}"
                                        data-action="click->range-filter#preset"
                                        data-from="{{ p.from }}" data-to="{{ p.to }}">
                                    {{ p.label }}
                                </button>
                            {% endfor %}
                        </div>
                    </div>

                    {# === Секция: Температура эксплуатации === #}
                    <div class="pb-3 mb-3 border-bottom">
                        <h6 class="fw-semibold mb-2">Температура эксплуатации</h6>
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small text-muted mb-1">°C</label>
                                <input type="number" name="thermTemp" value="{{ thermTemp }}"
                                       class="form-control form-control-sm"
                                       min="-100" max="500" step="5" placeholder="напр. 90">
                            </div>
                            <div class="col-6">
                                <label class="form-label small text-muted mb-1">Среда</label>
                                {% set thermEnvEffective = thermEnv ?: 'dry_heat' %}
                                <select name="thermEnv" class="form-select form-select-sm">
                                    <option value="dry_heat" {% if thermEnvEffective == 'dry_heat' %}selected{% endif %}>Сухое тепло</option>
                                    <option value="immersion" {% if thermEnvEffective == 'immersion' %}selected{% endif %}>Погружение</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input"
                                           id="thermPeakOff" name="thermPeak" value="1"
                                           {% if thermIncludingPeak %}checked{% endif %}>
                                    <label class="form-check-label small" for="thermPeakOff">Включая пиковые нагрузки</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# === Секция: Производитель === #}
                    <div class="pb-3 mb-3 border-bottom">
                        <h6 class="fw-semibold mb-2">Производитель</h6>
                        <div class="row g-1">
                            {% for m in manufacturers %}
                                <div class="col-12">
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input"
                                               name="manufacturerIds[]" value="{{ m.id }}"
                                               id="mfOff-{{ m.id }}"
                                               {% if m.id in selectedManufacturerIds.list %}checked{% endif %}>
                                        <label class="form-check-label" for="mfOff-{{ m.id }}">{{ m.title }}</label>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>

                    {# === Секция: Теги ===
                         Отдельный Tagify-инстанс со своим data-coating-tags-group scope,
                         hidden-input'ы пишутся здесь и подхватываются только этой формой
                         (шторки), не пересекаясь с другим Tagify в chip-row (в другой форме). #}
                    <div class="pb-3 mb-3" data-coating-tags-group>
                        <h6 class="fw-semibold mb-2">Теги</h6>
                        <input type="text"
                               data-controller="coating-tags"
                               data-coating-tags-existing-value="{{ selectedTagsJson }}"
                               data-coating-tags-suggest-url-value="{{ path('app_cabinet_coating_coating_tag_suggest') }}"
                               data-coating-tags-create-url-value="{{ path('app_cabinet_coating_coating_tag_create') }}"
                               data-coating-tags-hidden-input-name-value="tagIds[]"
                               data-coating-tags-allow-create-value="false"
                               class="form-control form-control-sm"
                               placeholder="Начните вводить тег...">
                    </div>
                </div>

                {# Sticky footer со сбросом всех и apply. #}
                <div class="border-top p-3 d-flex gap-2 bg-body">
                    <a href="{{ path('app_cabinet_coating_coating_list') }}" class="btn btn-outline-secondary flex-fill">
                        Сбросить всё
                    </a>
                    <button type="submit" class="btn btn-primary flex-fill">
                        Показать
                    </button>
                </div>
            </form>
        </div>

        {% if error %}
            <div class="alert alert-warning" role="alert">{{ error }}</div>
        {% endif %}
    {% endblock %}

    {% block list_content %}
        {# Счётчик над списком. Сортировка переехала в chip-row выше. #}
        <div class="mb-2 small text-muted">
            Найдено: <strong>{{ result.pager.total_items }}</strong>
        </div>

        {# Infinite scroll через общий components/infinite_list.html.twig
                   partial + assets/controllers/infinite_list_controller.js. base_url
                   фильтруется от page/partial — Stimulus сам их добавит для догрузки.
                   Deep-link ?page=N всё равно работает (server-side render'ит нужную страницу),
                   но сам base_url для fetch-а ими не загрязняется. #}
                {% set totalPages = (result.pager.total_items / result.pager.perPage)|round(0, 'ceil') %}
                {% set baseQuery = app.request.query.all|filter((v, k) => v is not null and k != 'page' and k != 'partial') %}
                {% include 'components/infinite_list.html.twig' with {
                    items_template: 'admin/coating/coating/_coating_cards_batch.html.twig',
                    items_params: {
                        coatings: result.coatings,
                        canEdit: canEdit,
                        selectedTagIdList: selectedTagIdList,
                        baseLabels: baseLabels,
                    },
                    total_pages: totalPages,
                    base_url: path('app_cabinet_coating_coating_list', baseQuery),
                } only %}

                {# Fallback: обычный pager для случая когда JS выключен или Stimulus
                   не поднялся. При работающем JS контроллер скрывает его. #}
                <noscript>
                    {% include 'components/pager.html.twig' with {'pager': result.pager} %}
                </noscript>

                {% if canEdit %}
                    {% include 'components/delete_modal.html.twig' with {'delete':'app_cabinet_coating_coating_delete'} %}
                {% endif %}
    {% endblock %}

    {% block empty_state %}
        {% if search %}
            {# Специфичное сообщение для поискового empty-state: показываем
               исходный запрос + подсказку. На multi-word fuzzy не отрабатывает
               по дизайну (см. CoatingRepository::findByFilter, Option C).
               Плашка не исчезает автоматически (см. base.html.twig auto-dismiss
               сужен до .flash-messages .alert). #}
            <div class="alert alert-warning text-center mt-3 py-4 shadow-sm" role="status">
                <i class="bi bi-search fs-1 d-block mb-2 text-secondary"></i>
                <h5 class="alert-heading mb-2">Ничего не найдено</h5>
                <p class="mb-2">
                    По запросу «<strong>{{ search }}</strong>» совпадений нет.
                </p>
                <p class="small text-muted mb-0">
                    Каждое слово должно встретиться в названии, описании или тегах.
                    Попробуйте сократить запрос или использовать другие слова.
                </p>
            </div>
        {% else %}
            {% include 'components/empty.html.twig' %}
        {% endif %}
    {% endblock %}
    {% endembed %}

        <div class="position-fixed bottom-0 start-50 translate-middle-x mb-3 d-none"
             style="z-index: 1080;"
             data-compare-tray-target="bar">
            <div class="card shadow">
                <div class="card-body py-2 px-3 d-flex align-items-center gap-3">
                    <span class="small">К сравнению: <strong data-compare-tray-target="count">0</strong></span>
                    <button type="button" class="btn btn-sm btn-primary"
                            data-action="click->compare-tray#open"
                            data-compare-tray-target="openBtn" disabled>
                        Сравнить
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary"
                            data-action="click->compare-tray#clear">
                        Очистить
                    </button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
