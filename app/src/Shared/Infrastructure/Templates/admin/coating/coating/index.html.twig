    {% block list_content %}
        {# Счётчик над списком. Сортировка переехала в chip-row выше. #}
        <div class="mb-2 small text-muted">
            Найдено: <strong>{{ result.pager.total_items }}</strong>
        </div>

        {# Infinite scroll через общий components/infinite_list.html.twig
                   partial + assets/controllers/infinite_list_controller.js. base_url
                   фильтруется от page/partial — Stimulus сам их добавит для догрузки.
                   Deep-link ?page=N всё равно работает (server-side render'ит нужную страницу),
                   но сам base_url для fetch-а ими не загрязняется. #}
                {% set totalPages = (result.pager.total_items / result.pager.perPage)|round(0, 'ceil') %}
                {% set baseQuery = app.request.query.all|filter((v, k) => v is not null and k != 'page' and k != 'partial') %}
                {% include 'components/infinite_list.html.twig' with {
                    items_template: 'admin/coating/coating/_coating_cards_batch.html.twig',
                    items_params: {
                        coatings: result.coatings,
                        canEdit: canEdit,
                        selectedTagIdList: selectedTagIdList,
                        baseLabels: baseLabels,
                    },
                    total_pages: totalPages,
                    base_url: path('app_cabinet_coating_coating_list', baseQuery),
                } only %}

                {# Fallback: обычный pager для случая когда JS выключен или Stimulus
                   не поднялся. При работающем JS контроллер скрывает его. #}
                <noscript>
                    {% include 'components/pager.html.twig' with {'pager': result.pager} %}
                </noscript>

                {% if canEdit %}
                    {% include 'components/delete_modal.html.twig' with {'delete':'app_cabinet_coating_coating_delete'} %}
                {% endif %}
    {% endblock %}

    {% block empty_state %}
        {% if search %}
            {# Специфичное сообщение для поискового empty-state: показываем
               исходный запрос + подсказку. На multi-word fuzzy не отрабатывает
               по дизайну (см. CoatingRepository::findByFilter, Option C).
               Плашка не исчезает автоматически (см. base.html.twig auto-dismiss
               сужен до .flash-messages .alert). #}
            <div class="alert alert-warning text-center mt-3 py-4 shadow-sm" role="status">
                <i class="bi bi-search fs-1 d-block mb-2 text-secondary"></i>
                <h5 class="alert-heading mb-2">Ничего не найдено</h5>
                <p class="mb-2">
                    По запросу «<strong>{{ search }}</strong>» совпадений нет.
                </p>
                <p class="small text-muted mb-0">
                    Каждое слово должно встретиться в названии, описании или тегах.
                    Попробуйте сократить запрос или использовать другие слова.
                </p>
            </div>
        {% else %}
            {% include 'components/empty.html.twig' %}
        {% endif %}
    {% endblock %}
    {% endembed %}

        <div class="position-fixed bottom-0 start-50 translate-middle-x mb-3 d-none"
             style="z-index: 1080;"
             data-compare-tray-target="bar">
            <div class="card shadow">
                <div class="card-body py-2 px-3 d-flex align-items-center gap-3">
                    <span class="small">К сравнению: <strong data-compare-tray-target="count">0</strong></span>
                    <button type="button" class="btn btn-sm btn-primary"
                            data-action="click->compare-tray#open"
                            data-compare-tray-target="openBtn" disabled>
                        Сравнить
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary"
                            data-action="click->compare-tray#clear">
                        Очистить
                    </button>
                </div>
            </div>
        </div>
    </div>

    {# Chip-фильтры: адаптивная логика desktop-dropdown vs mobile-offcanvas.

       1) Desktop Popper-конфиг для chip-dropdown'ов внутри chip-desktop-panel:
          preventOverflow.boundary = col-обёртка из list_page.html.twig
          (родитель формы). Ширина совпадает со списком, altAxis: true
          удерживает меню в этой ширине — иначе крайний правый chip-dropdown
          (или новые фильтры при добавлении) вылезал за правый край списка.

       2) Viewport-adaptive disabled на fieldset'ах.
          Инпуты из невидимого viewport'a (например, mobile offcanvas при
          десктопной ширине) физически остаются в form. Если бы они были
          enabled, browser отправлял бы их значения при submit — а для
          hidden'ов range-фильтра и thermTemp это значит, что пустой mobile
          input перезатирает установленный desktop-ом.
          Решение: mediaMatch (min-width: 768px) → disabled на fieldset'ах
          противоположного viewport'a. Disabled fieldset выключает все его
          input'ы (и submit-кнопки) для form-submit'а. #}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Desktop Popper: удержание в границе col-обёртки.
            document.querySelectorAll('.chip-desktop-panel [data-bs-toggle="dropdown"]').forEach(el => {
                const boundary = el.closest('form')?.parentElement ?? document.body;
                bootstrap.Dropdown.getInstance(el)?.dispose();
                new bootstrap.Dropdown(el, {
                    popperConfig: (defaultConfig) => ({
                        ...defaultConfig,
                        modifiers: [
                            ...defaultConfig.modifiers.filter(m => m.name !== 'preventOverflow'),
                            {
                                name: 'preventOverflow',
                                options: { boundary, altAxis: true, padding: 8 },
                            },
                        ],
                    }),
                });
            });

            // Viewport-adaptive disable для фильтр-fieldset'ов.
            const mq = window.matchMedia('(min-width: 768px)');
            const desktopPanels = document.querySelectorAll('.chip-desktop-panel');
            const mobilePanels = document.querySelectorAll('.chip-mobile-panel');
            const apply = () => {
                const isDesktop = mq.matches;
                desktopPanels.forEach(f => { f.disabled = !isDesktop; });
                mobilePanels.forEach(f => { f.disabled = isDesktop; });
            };
            apply();
            mq.addEventListener('change', apply);
        });
    </script>
{% endblock %}
