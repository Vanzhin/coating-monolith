{% extends '/cabinet/index.html.twig' %}

{% block title %}{{ parent() }} | Редактирование оценки{% endblock %}

{% set currentNoteIds = inputData.noteIds is defined
    ? inputData['noteIds']
    : assessment.noteIds.list %}

{% block content %}
<div class="p-2 p-md-3">
    <form method="post"
          action="{{ path('app_cabinet_coating_chem_resistance_assessment_update', {
              coatingId: coatingId,
              assessmentId: assessmentId
          }) }}"
          class="w-100">

        {% if error is defined and error %}
            <div class="alert alert-danger">{{ error }}</div>
        {% endif %}

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Редактирование оценки</h1>
            <a href="{{ path('app_cabinet_coating_chem_resistance_edit', {coatingId: coatingId}) }}"
               class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> К списку оценок
            </a>
        </div>

        <div class="p-3 mb-3 rounded-3 bg-body-tertiary">
            <h6 class="fw-semibold mb-3">Покрытие</h6>
            <p class="mb-0">{{ coating.title }}</p>
        </div>

        <div class="p-3 mb-3 rounded-3 bg-body-tertiary">
            <h6 class="fw-semibold mb-3">Вещество</h6>
            <p class="mb-0">
                {% if substance is not null %}
                    {{ substance.canonicalName }}
                    {% if substance.cas is not null %}
                        <span class="text-muted small">CAS {{ substance.cas.value }}</span>
                    {% endif %}
                {% else %}
                    <span class="text-muted">Неизвестно</span>
                {% endif %}
            </p>
        </div>

        <div class="p-3 mb-3 rounded-3 bg-body-tertiary">
            <h6 class="fw-semibold mb-3">Параметры оценки</h6>
            <div class="row g-3">
                <div class="col-md-4">
                    <label for="inputGrade" class="form-label">Оценка <span class="text-danger">*</span></label>
                    {% set currentGrade = inputData.grade is defined ? inputData.grade : assessment.grade.value %}
                    <select name="grade" id="inputGrade" class="form-select" required>
                        <option value="R"  {% if currentGrade == 'R'  %}selected{% endif %}>R — стойкое</option>
                        <option value="LR" {% if currentGrade == 'LR' %}selected{% endif %}>LR — ограниченно</option>
                        <option value="NR" {% if currentGrade == 'NR' %}selected{% endif %}>NR — нестойкое</option>
                        <option value="FS" {% if currentGrade == 'FS' %}selected{% endif %}>FS — спец. условия</option>
                        <option value="NT" {% if currentGrade == 'NT' %}selected{% endif %}>NT — не испытано</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label for="inputMaxTemp" class="form-label">Максимальная температура, °C</label>
                    {% set currentTemp = inputData.maxTemperatureCelsius is defined
                        ? inputData.maxTemperatureCelsius
                        : assessment.maxTemperature.celsius %}
                    <input type="number"
                           name="maxTemperatureCelsius"
                           id="inputMaxTemp"
                           class="form-control"
                           min="1" max="500"
                           placeholder="напр. 40"
                           value="{{ currentTemp }}">
                    <div class="form-text">Оставьте пустым, если не ограничена.</div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Примечания</label>
                    <select name="noteIds[]" class="form-select" multiple size="6">
                        {% for note in allNotes %}
                            <option value="{{ note.id }}"
                                    {% if note.id in currentNoteIds %}selected{% endif %}>
                                {{ note.title }}
                            </option>
                        {% endfor %}
                    </select>
                    <div class="form-text">Удерживайте Ctrl / Cmd для выбора нескольких.</div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2">
            <a href="{{ path('app_cabinet_coating_chem_resistance_edit', {coatingId: coatingId}) }}"
               class="btn btn-outline-secondary">Отмена</a>
            <button class="btn btn-primary" type="submit">Сохранить</button>
        </div>
    </form>
</div>
{% endblock %}
