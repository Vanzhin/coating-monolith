{% extends '/cabinet/index.html.twig' %}

{% block title %}{{ parent() }} | Примечания{% endblock %}

{% block content %}
    {% set canEdit = is_granted('ROLE_ADMIN') %}

    {% embed 'components/list_page.html.twig' with {
        title: 'Примечания',
        create_route: 'app_cabinet_chemical_resistance_note_create',
        can_edit: canEdit,
        is_empty: result.notes is empty,
    } %}
        {% block above_list %}
            <form method="get" action="{{ path('app_cabinet_chemical_resistance_note_list') }}" class="mb-0">
                <div class="input-group">
                    <input type="search" name="search" value="{{ app.request.query.get('search') }}"
                           class="form-control"
                           placeholder="Поиск по названию или описанию..."
                           autocomplete="off">
                    <button type="submit" class="btn btn-primary">Найти</button>
                </div>
            </form>
        {% endblock %}

        {% block list_content %}
            <div class="d-flex flex-column gap-2">
                {% for note in result.notes %}
                    <div class="d-flex align-items-start gap-2 gap-md-3 p-3 rounded-3 bg-body">
                        <div class="flex-grow-1 overflow-hidden">
                            <h6 class="mb-1 fw-semibold" style="word-break: break-word;">
                                {{ note.title }}
                            </h6>
                            <div class="small text-muted">
                                {% set description = note.description %}
                                {% if description|length > 100 %}
                                    {{ description|slice(0, 100) }}…
                                {% else %}
                                    {{ description }}
                                {% endif %}
                            </div>
                        </div>
                        {% if canEdit %}
                            <div class="d-flex gap-1 gap-md-2 flex-shrink-0 flex-column flex-md-row">
                                {% include '/components/edit_delete.html.twig' with {
                                    'edit':   'app_cabinet_chemical_resistance_note_update',
                                    'delete': 'app_cabinet_chemical_resistance_note_delete',
                                    'id':     note.id,
                                    'title':  note.title,
                                    'name':   'примечания'
                                } %}
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>

            {% if canEdit %}
                {% include 'components/delete_modal.html.twig' with {'delete': 'app_cabinet_chemical_resistance_note_delete'} %}
            {% endif %}
        {% endblock %}

        {% block below_list %}
            {% include 'components/pager.html.twig' with {'pager': result.pager} %}
        {% endblock %}
    {% endembed %}
{% endblock %}
