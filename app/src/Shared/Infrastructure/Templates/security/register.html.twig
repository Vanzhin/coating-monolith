{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} · Регистрация{% endblock %}

{# Неавторизованные страницы — только форма без хедера/футера. #}
{% block header %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}
    <div class="container-fluid p-3">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                {% if app.user %}
                    <div class="p-3 mb-3 rounded-3 bg-body-tertiary text-center">
                        Вы вошли как <strong>{{ app.user.userIdentifier }}</strong>.
                        <a href="{{ path('app_logout') }}">Выйти</a>
                    </div>
                {% endif %}

                <div class="p-4 rounded-3 bg-body-tertiary">
                    <h1 class="h4 fw-semibold mb-3 text-center">Регистрация</h1>

                    {# Flash-сообщения от контроллера (register_failure / register_success). #}
                    {% for message in app.flashes('register_failure') %}
                        <div class="alert alert-danger">{{ message }}</div>
                    {% endfor %}
                    {% for message in app.flashes('register_success') %}
                        <div class="alert alert-success">{{ message }}</div>
                    {% endfor %}

                    {# Symfony Form отдаёт поля с name="registration_form[...]" и
                       свой CSRF-токен. Стиль — form-floating (у Symfony bootstrap_5
                       theme его нет), поэтому inputs пишем руками, а name/id/errors
                       берём из FormView. #}
                    <form method="post" action="{{ path('app_sign_up') }}">
                        <div class="form-floating mb-2">
                            <input type="email"
                                   id="{{ registrationForm.email.vars.id }}"
                                   name="{{ registrationForm.email.vars.full_name }}"
                                   value="{{ registrationForm.email.vars.value }}"
                                   class="form-control{% if not registrationForm.email.vars.valid %} is-invalid{% endif %}"
                                   autocomplete="email"
                                   required autofocus placeholder="you@example.com">
                            <label for="{{ registrationForm.email.vars.id }}">Email</label>
                            {{ form_errors(registrationForm.email) }}
                        </div>

                        <div class="form-floating mb-3">
                            <input type="password"
                                   id="{{ registrationForm.plainPassword.vars.id }}"
                                   name="{{ registrationForm.plainPassword.vars.full_name }}"
                                   class="form-control{% if not registrationForm.plainPassword.vars.valid %} is-invalid{% endif %}"
                                   autocomplete="new-password"
                                   required placeholder="Пароль">
                            <label for="{{ registrationForm.plainPassword.vars.id }}">Пароль</label>
                            {{ form_errors(registrationForm.plainPassword) }}
                        </div>

                        {# CSRF-токен генерирует Symfony Form сам — рендерим виджет. #}
                        {{ form_widget(registrationForm._token) }}

                        <button class="btn btn-primary w-100" type="submit">Зарегистрироваться</button>
                    </form>

                    <hr class="my-3">

                    <div class="small text-body-secondary text-center">
                        Уже есть аккаунт? <a href="{{ path('app_login') }}">Войти</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
