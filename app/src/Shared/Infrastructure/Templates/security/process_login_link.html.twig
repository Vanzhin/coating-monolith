{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} · Подтверждение входа{% endblock %}

{# Неавторизованные страницы — только контент без хедера/футера. #}
{% block header %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}
    <div class="container-fluid p-3">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                {% if app.user %}
                    <div class="p-3 mb-3 rounded-3 bg-body-tertiary text-center">
                        Вы уже вошли как <strong>{{ app.user.userIdentifier }}</strong>.
                        <a href="{{ path('app_logout') }}">Выйти</a>
                    </div>
                {% endif %}

                <div class="p-4 rounded-3 bg-body-tertiary text-center">
                    <i class="bi bi-shield-check display-4 text-primary d-block mb-3"></i>
                    <h1 class="h4 fw-semibold mb-2">Подтверждение входа</h1>
                    <p class="text-body-secondary mb-3">
                        Нажмите кнопку, чтобы завершить вход по ссылке.
                    </p>

                    <form method="POST" action="{{ path('app_login_check') }}">
                        <input type="hidden" name="expires" value="{{ expires }}">
                        <input type="hidden" name="user" value="{{ user }}">
                        <input type="hidden" name="hash" value="{{ hash }}">
                        <button class="btn btn-primary w-100" type="submit">Войти</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
