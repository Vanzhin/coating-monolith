{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} · Вход по ссылке{% endblock %}

{# Неавторизованные страницы — только форма без хедера/футера. #}
{% block header %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}
    <div class="container-fluid p-3">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                {% if app.user %}
                    <div class="p-3 mb-3 rounded-3 bg-body-tertiary text-center">
                        Вы вошли как <strong>{{ app.user.userIdentifier }}</strong>.
                        <a href="{{ path('app_logout') }}">Выйти</a>
                    </div>
                {% else %}
                    <div class="p-4 rounded-3 bg-body-tertiary">
                        <h1 class="h4 fw-semibold mb-2 text-center">Вход по ссылке</h1>
                        <p class="small text-body-secondary text-center mb-3">
                            Введите email — пришлём ссылку для одноразового входа.
                        </p>

                        {% if error is defined and error %}
                            <div class="alert alert-warning">{{ error }}</div>
                        {% endif %}

                        <form method="post" action="{{ path('app_login_link') }}">
                            <div class="form-floating mb-3">
                                <input type="email" value="{{ email }}" name="email" id="inputEmail"
                                       class="form-control" autocomplete="email"
                                       required autofocus placeholder="you@example.com">
                                <label for="inputEmail">Email</label>
                            </div>

                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('login_link') }}">

                            <button class="btn btn-primary w-100" type="submit">Отправить ссылку</button>
                        </form>

                        <hr class="my-3">

                        <div class="small text-body-secondary text-center">
                            <a href="{{ path('app_login') }}">Вернуться ко входу с паролем</a>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
